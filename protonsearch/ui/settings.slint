        // Main Content Area
        Rectangle {
            background: root.bg-color;
            
            VerticalBox {
                padding: 0;
                spacing: 0;
                
                ScrollView {
                    VerticalBox {
                        alignment: start;
                        padding: 24px;
                        spacing: 12px;
                    
                    // General Page
                    if root.current-page == 0: VerticalBox {
                        alignment: start;
                        spacing: 20px;

                        // Page header
                        VerticalBox {
                            spacing: 4px;
                            Text {
                                text: "General";
                                font-size: 30px;
                                font-weight: 700;
                                color: root.text-primary;
                            }
                        }

                        // Section: Behavior
                        VerticalBox {
                            spacing: 2px;
                            Text {
                                text: "BEHAVIOR";
                                font-size: 11px;
                                font-weight: 600;
                                color: root.text-muted;
                                letter-spacing: 1px;
                            }
                            Rectangle { height: 6px; }

                            // Run on startup row
                            Rectangle {
                                background: root.card-bg;
                                border-radius: 8px;
                                border-color: root.border-color;
                                border-width: 1px;
                                height: 64px;
                                HorizontalBox {
                                    padding-left: 20px;
                                    padding-right: 20px;
                                    spacing: 16px;

                                    VerticalBox {
                                        alignment: center;
                                        spacing: 2px;
                                        Text { text: "Run on startup"; color: root.text-primary; font-size: 14px; font-weight: 600; }
                                        Text { text: "Launch ProtonSearch when Windows starts"; color: root.text-muted; font-size: 12px; }
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    VerticalBox {
                                        alignment: center;
                                        ToggleSwitch {
                                            checked <=> root.run-on-startup;
                                            toggled => {
                                                root.save-settings();
                                            }
                                        }
                                    }
                                }
                            }

                            Rectangle { height: 6px; }

