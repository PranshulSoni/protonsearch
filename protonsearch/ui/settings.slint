                                        Text { text: "Search window location"; color: root.text-primary; font-size: 14px; font-weight: 600; }
                                        Text { text: "Monitor/position where the launcher window appears"; color: root.text-muted; font-size: 12px; }
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    VerticalBox {
                                        alignment: center;
                                        ComboBox {
                                            width: 220px;
                                            height: 40px;
                                            model: [
                                                "Remember Last Position",
                                                "Monitor with Mouse Cursor",
                                                "Monitor with Focused Window",
                                                "Primary Monitor",
                                                "Custom Monitor"
                                            ];
                                            current-value: root.window-location;
                                            selected(val) => {
                                                root.window-location = val;
                                                root.save-settings();
                                            }
                                        }
                                    }
                                }
                            }

                            Rectangle { height: 120px; }
                        }
                    }
                    
                    // Appearance Page
                    if root.current-page == 1: VerticalBox {
                        alignment: start;
                        spacing: 16px;
                        
                        Text { text: "Appearance"; font-size: 30px; font-weight: 700; color: root.text-primary; }
                        
                        // Preview & Edits Container (At the Top!)
                        HorizontalBox {
                            spacing: 16px;
                            
                            // Left Preview Area
                            Rectangle {
                                border-radius: 8px;
                                border-width: 1px;
                                border-color: root.border-color;
                                height: 440px;
                                horizontal-stretch: 1;
                                clip: true;

                                // Background image (User's wallpaper)
                                if root.has-desktop-wallpaper : Image {
                                    source: root.desktop-wallpaper;
                                    image-fit: cover;
                                    width: 100%;
                                    height: 100%;
                                }

                                // Fallback gradient if no wallpaper is loaded
                                if !root.has-desktop-wallpaper : Rectangle {
                                    background: @linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
                                    width: 100%;
                                    height: 100%;
                                }

                                // The Mockup Launcher Popup (exactly matching the user's photos)
                                Rectangle {
                                    width: 440px;
                                    height: 250px;
                                    background: root.theme-mode == "Light" ? #ffffff : (root.theme-mode == "NordDarker" ? #232731 : #1c1c1c);
                                    border-radius: 12px;
                                    border-width: 1px;
                                    border-color: root.theme-mode == "Light" ? #e0e0e0 : (root.theme-mode == "NordDarker" ? #3b4252 : #2d2d2d);
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;

                                    VerticalLayout {
                                        padding: 0;
                                        spacing: 0;
                                        
                                        // Mockup Search Input Box
                                        Rectangle {
                                            height: root.search-bar-height * 0.7px;

                                            Rectangle {
                                                y: parent.height - 1px;
                                                height: 1px;
                                                background: root.theme-mode == "Light" ? #f2f2f2 : (root.theme-mode == "NordDarker" ? #3b4252 : #2a2a2a);
                                            }

                                            HorizontalLayout {
                                                padding-left: 16px;
                                                padding-right: 16px;
                                                spacing: 12px;
                                                
                                                // Search Icon
                                                Text {
                                                    text: "\u{e721}";
                                                    font-family: "Segoe MDL2 Assets";
                                                    font-size: 22px;
                                                    color: root.theme-mode == "Light" ? #343434 : #d8d8d8;
                                                    vertical-alignment: center;
                                                }

                                                // Search Text Placeholder or Caret cursor
                                                if root.show-placeholder : Text {
                                                    text: "Search files, code, PDFs, OCR...";
                                                    font-family: root.query-font-family;
                                                    font-size: root.query-font-size * 0.65px;
                                                    font-weight: root.query-font-weight == "Bold" ? 700 : (root.query-font-weight == "Semi-Bold" ? 600 : 400);
                                                    color: root.theme-mode == "Light" ? #8e8e93 : (root.theme-mode == "NordDarker" ? #4c566a : #6b6b6b);
                                                    vertical-alignment: center;
                                                }

                                                if !root.show-placeholder : Rectangle {
                                                    width: 2px;
                                                    height: root.query-font-size * 0.75px;
                                                    background: root.theme-mode == "Light" ? #000000 : (root.theme-mode == "NordDarker" ? #88c0d0 : #ffffff);
                                                    opacity: 0.95;
                                                }

                                                Rectangle { } // Spacer
                                            }
                                        }

                                        // Mockup Results Area
                                        VerticalLayout {
                                            padding-left: 8px;
                                            padding-right: 8px;
                                            padding-top: 6px;
                                            padding-bottom: 6px;
                                            spacing: 4px;

                                            // Mockup Item 1: Browser Bookmarks
                                            Rectangle {
                                                height: 34px;
                                                background: transparent;
                                                border-radius: 4px;
                                                HorizontalLayout {
                                                    padding-left: 8px;
                                                    padding-right: 8px;
                                                    spacing: 12px;
                                                     Text { text: "⭐"; font-size: 14px; vertical-alignment: center; }
                                                    VerticalLayout {
                                                        alignment: center;
                                                        spacing: 0;
                                                        Text { text: "Browser Bookmarks"; font-size: 11px; font-weight: 600; color: root.theme-mode == "Light" ? #222222 : #d8dee9; }
                                                        Text { text: "Browser > Bookmarks"; font-size: 9px; color: root.theme-mode == "Light" ? #888888 : #4c566a; }
                                                    }
                                                    Rectangle { } // Spacer
                                                    Text { text: "Browser"; font-size: 9px; color: root.theme-mode == "Light" ? #777777 : #4c566a; vertical-alignment: center; }
                                                }
                                            }

                                            // Mockup Item 2: Browser History
                                            Rectangle {
                                                height: 34px;
                                                background: transparent;
                                                border-radius: 4px;
                                                HorizontalLayout {
                                                    padding-left: 8px;
                                                    padding-right: 8px;
                                                    spacing: 12px;
                                                     Text { text: "🌐"; font-size: 14px; vertical-alignment: center; }
                                                    VerticalLayout {
                                                        alignment: center;
                                                        spacing: 0;
                                                        Text { text: "Browser History"; font-size: 11px; font-weight: 600; color: root.theme-mode == "Light" ? #222222 : #d8dee9; }
                                                        Text { text: "Browser > History"; font-size: 9px; color: root.theme-mode == "Light" ? #888888 : #4c566a; }
                                                    }
                                                    Rectangle { } // Spacer
                                                    Text { text: "Browser"; font-size: 9px; color: root.theme-mode == "Light" ? #777777 : #4c566a; vertical-alignment: center; }
                                                }
                                            }

                                            // Mockup Item 3: Git Commits (Selected / Active)
                                            Rectangle {
                                                height: 34px;
                                                background: root.theme-mode == "Light" ? #e5e5e5 : (root.theme-mode == "NordDarker" ? #3b4252 : #2f2f2f);
                                                border-radius: 4px;
                                                HorizontalLayout {
                                                    padding-left: 8px;
                                                    padding-right: 8px;
                                                    spacing: 12px;
                                                     Text { text: "💬"; font-size: 14px; vertical-alignment: center; }
                                                    VerticalLayout {
                                                        alignment: center;
                                                        spacing: 0;
                                                        Text { text: "Git Commits"; font-size: 11px; font-weight: 600; color: root.theme-mode == "Light" ? #111111 : #ffffff; }
                                                        Text { text: "Git > Commits"; font-size: 9px; color: root.theme-mode == "Light" ? #666666 : #bbbbbb; }
                                                    }
                                                    Rectangle { } // Spacer
                                                    Text { text: "Git"; font-size: 9px; color: root.theme-mode == "Light" ? #555555 : #999999; vertical-alignment: center; }
                                                }
                                            }

                                            // Mockup Item 4: Clipboard History
                                            Rectangle {
                                                height: 34px;
                                                background: transparent;
                                                border-radius: 4px;
                                                HorizontalLayout {
                                                    padding-left: 8px;
                                                    padding-right: 8px;
                                                    spacing: 12px;
                                                     Text { text: "📋"; font-size: 14px; vertical-alignment: center; }
                                                    VerticalLayout {
                                                        alignment: center;
                                                        spacing: 0;
                                                        Text { text: "Clipboard History"; font-size: 11px; font-weight: 600; color: root.theme-mode == "Light" ? #222222 : #d8dee9; }
                                                        Text { text: "Clipboard > History"; font-size: 9px; color: root.theme-mode == "Light" ? #888888 : #4c566a; }
                                                    }
                                                    Rectangle { } // Spacer
                                                    Text { text: "Clipboard"; font-size: 9px; color: root.theme-mode == "Light" ? #777777 : #4c566a; vertical-alignment: center; }
                                                }
                                            }



                                            // Mockup Item 8: Agent History
                                            Rectangle {
                                                height: 34px;
                                                background: transparent;
                                                border-radius: 4px;
                                                HorizontalLayout {
                                                    padding-left: 8px;
                                                    padding-right: 8px;
                                                    spacing: 12px;
                                                     Text { text: "🤖"; font-size: 14px; vertical-alignment: center; }
                                                    VerticalLayout {
                                                        alignment: center;
                                                        spacing: 0;
                                                        Text { text: "Agent History"; font-size: 11px; font-weight: 600; color: root.theme-mode == "Light" ? #222222 : #d8dee9; }
                                                        Text { text: "AI > Agent runs"; font-size: 9px; color: root.theme-mode == "Light" ? #888888 : #4c566a; }
                                                    }
                                                    Rectangle { } // Spacer
                                                    Text { text: "AI"; font-size: 9px; color: root.theme-mode == "Light" ? #777777 : #4c566a; vertical-alignment: center; }
                                                }
                                            }
                                        }
                                    }
                                }

                                // Edit Button top-right (Text based to prevent missing glyph box)
                                Rectangle {
                                    width: 48px;
                                    height: 24px;
                                    background: edit-btn-ta.has-hover ? #ffffff30 : #ffffff1a;
                                    border-radius: 4px;
                                    x: parent.width - self.width - 12px;
                                    y: 12px;
                                    
                                    Text {
                                        text: "Edit";
                                        color: #ffffff;
                                        font-size: 11px;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                    
                                    edit-btn-ta := TouchArea {
                                        clicked => {
                                            root.edit-panel-expanded = !root.edit-panel-expanded;
                                        }
                                    }
                                }
                            }

                            // Right Edit Panel (Only if expanded)
                            if root.edit-panel-expanded : Rectangle {
                                width: 320px;
                                background: root.card-bg;
                                border-radius: 8px;
                                border-width: 1px;
                                border-color: root.border-color;
                                height: 440px;

                                ScrollView {
                                    VerticalBox {
                                        padding: 16px;
                                        spacing: 12px;
                                        
                                        Text { text: "Edit Layout & Fonts"; font-size: 15px; font-weight: 600; color: root.text-primary; }
                                        
                                        // Search Bar Height Slider
                                        VerticalBox {
                                            spacing: 4px;
                                            HorizontalBox {
                                                padding: 0;
                                                Text { text: "Search Bar Height"; color: root.text-secondary; font-size: 12px; }
                                                Rectangle { horizontal-stretch: 1; }
                                                Text { text: root.search-bar-height + "px"; color: root.accent; font-size: 12px; font-weight: 600; }
                                            }
                                            Slider {
                                                minimum: 40;
                                                maximum: 80;
                                                value: root.search-bar-height;
                                                changed(val) => {
                                                    root.search-bar-height = val;
                                                    root.save-settings();
                                                }
                                            }
                                        }

                                        // Query Box Font Family & Weight & Size
                                        VerticalBox {
                                            spacing: 4px;
                                            Text { text: "Query Font Family"; color: root.text-secondary; font-size: 12px; }
                                            ComboBox {
                                                width: 100%;
                                                height: 38px;
                                                model: ["Segoe UI Variable", "Arial", "Consolas", "Outfit"];
                                                current-value: root.query-font-family;
                                                selected(val) => {
                                                    root.query-font-family = val;
                                                    root.save-settings();
                                                }
                                            }
                                            Text { text: "Query Font Weight"; color: root.text-secondary; font-size: 12px; }
                                            ComboBox {
                                                width: 100%;
                                                height: 38px;
                                                model: ["Regular", "Semi-Bold", "Bold"];
                                                current-value: root.query-font-weight;
                                                selected(val) => {
                                                    root.query-font-weight = val;
                                                    root.save-settings();
                                                }
                                            }
                                            HorizontalBox {
                                                padding: 0;
                                                Text { text: "Query Font Size"; color: root.text-secondary; font-size: 12px; }
                                                Rectangle { horizontal-stretch: 1; }
                                                Text { text: root.query-font-size + "px"; color: root.accent; font-size: 12px; font-weight: 600; }
                                            }
                                            Slider {
                                                minimum: 14;
                                                maximum: 32;
                                                value: root.query-font-size;
                                                changed(val) => {
                                                    root.query-font-size = val;
                                                    root.save-settings();
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                        
                        // Launcher theme row
                        Text { text: "Launcher Theme"; font-size: 13px; color: root.text-muted; }
                        Rectangle {
                            background: root.card-bg;
                            border-radius: 8px;
                            border-color: root.border-color;
                            border-width: 1px;
                            padding: 16px;
                            HorizontalBox {
                                spacing: 12px;
                                alignment: start;
                                // Light card
                                Rectangle {
                                    height: 90px;
                                    width: 130px;
                                    border-radius: 8px;
                                    border-width: root.theme-mode == "Light" ? 2px : 1px;
                                    border-color: root.theme-mode == "Light" ? #1d90f3 : root.border-color;
                                    background: #ffffff;
                                    VerticalBox {
                                        padding: 10px;
                                        spacing: 6px;
                                        Text { text: "Light"; color: #111111; font-weight: 600; font-size: 12px; }
                                        Rectangle { height: 16px; border-radius: 4px; background: #f2f2f2; }
                                        Rectangle { height: 16px; border-radius: 4px; background: #e5e5e5; }
                                    }
                                    TouchArea { clicked => { root.theme-mode = "Light"; root.save-settings(); } }
                                }
                                // Dark card
                                Rectangle {
                                    height: 90px;
                                    width: 130px;
                                    border-radius: 8px;
                                    border-width: root.theme-mode == "Dark" ? 2px : 1px;
                                    border-color: root.theme-mode == "Dark" ? #1d90f3 : root.border-color;
                                    background: #1e1e1e;
                                    VerticalBox {
                                        padding: 10px;
                                        spacing: 6px;
                                        Text { text: "Dark"; color: #ffffff; font-weight: 600; font-size: 12px; }
                                        Rectangle { height: 16px; border-radius: 4px; background: #2f2f2f; }
                                        Rectangle { height: 16px; border-radius: 4px; background: #3a3a3a; }
                                    }
                                    TouchArea { clicked => { root.theme-mode = "Dark"; root.save-settings(); } }
                                }
                                // Nord card
                                Rectangle {
                                    height: 90px;
                                    width: 130px;
                                    border-radius: 8px;
                                    border-width: root.theme-mode == "NordDarker" ? 2px : 1px;
                                    border-color: root.theme-mode == "NordDarker" ? #1d90f3 : root.border-color;
                                    background: #2e3440;
                                    VerticalBox {
                                        padding: 10px;
                                        spacing: 6px;
                                        Text { text: "Nord Dark"; color: #e5e9f0; font-weight: 600; font-size: 12px; }
                                        Rectangle { height: 16px; border-radius: 4px; background: #3b4252; }
                                        Rectangle { height: 16px; border-radius: 4px; background: #4c566a; }
                                    }
                                    TouchArea { clicked => { root.theme-mode = "NordDarker"; root.save-settings(); } }
                                }
                            }
                        }

                        // Show placeholder setting
                        Rectangle {
                            background: root.card-bg;
                            border-radius: 8px;
                            border-color: root.border-color;
                            border-width: 1px;
                            height: 64px;
                            HorizontalBox {
                                padding-left: 20px;
                                padding-right: 20px;
                                spacing: 16px;
                                VerticalBox {
                                    alignment: center;
                                    spacing: 2px;
                                    Text { text: "Show placeholder"; color: root.text-primary; font-size: 14px; font-weight: 600; }
                                    Text { text: "Display placeholder when query is empty"; color: root.text-muted; font-size: 12px; }
                                }
                                Rectangle { horizontal-stretch: 1; }
                                VerticalBox {
                                    alignment: center;
                                    ToggleSwitch {
                                        checked <=> root.show-placeholder;
                                        toggled => {
                                            root.save-settings();
                                        }
                                    }
                                }
                            }
                        }

                        // Bottom Spacer
                        Rectangle { height: 60px; }
                    }
                    
                    // Hotkeys Page
                    if root.current-page == 2: VerticalBox {
                        alignment: start;
                        spacing: 24px;

                        // Header
                        VerticalBox {
                            spacing: 4px;
                            Text { text: "Hotkeys"; font-size: 30px; font-weight: 700; color: root.text-primary; }
                        }

                        // Open launcher hotkey card â€” four dropdowns (slots 1 & 2 required)
                        Rectangle {
                            background: root.card-bg;
                            border-radius: 8px;
                            border-color: root.border-color;
                            border-width: 1px;

                            VerticalLayout {
                                padding: 20px;
                                spacing: 14px;

                                HorizontalBox {
                                    spacing: 16px;
                                    padding: 0;

                                    VerticalBox {
                                        alignment: center;
                                        spacing: 2px;
                                        Text { text: "Open launcher"; color: root.text-primary; font-size: 14px; font-weight: 600; }
                                        Text { text: "Toggles the search window"; color: root.text-muted; font-size: 12px; }
                                    }

                                    Rectangle { horizontal-stretch: 1; }

                                    Rectangle {
                                        height: 34px;
                                        min-width: 150px;
                                        border-radius: 6px;
                                        border-width: 1px;
                                        border-color: root.border-color;
                                        background: root.bg-color;
                                        Text {
                                            text: root.global-hotkey;
                                            color: root.text-primary;
                                            font-size: 14px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 10px;

                                    ComboBox {
                                        width: 110px;
                                        height: 40px;
                                        model: root.slot1-model;
                                        current-value <=> root.slot1-val;
                                        selected => { root.apply-hotkey(); }
                                    }

                                    ComboBox {
                                        width: 110px;
                                        height: 40px;
                                        model: root.slot2-model;
                                        current-value <=> root.slot2-val;
                                        selected => { root.apply-hotkey(); }
                                    }
                                    ComboBox {
                                        width: 110px;
                                        height: 40px;
                                        model: root.slot34-model;
                                        current-value <=> root.slot3-val;
                                        selected => { root.apply-hotkey(); }
                                    }
                                    ComboBox {
                                        width: 110px;
                                        height: 40px;
                                        model: root.slot34-model;
                                        current-value <=> root.slot4-val;
                                        selected => { root.apply-hotkey(); }
                                    }
                                    
                                    // Pushes all ComboBoxes to the left cleanly
                                    Rectangle { horizontal-stretch: 1; }
                                }
                            }
                        }

                        Rectangle { height: 6px; }

                        // Availability banner â€” validates against real Win32 global hotkey registration.
                        if root.hotkey-error != "": Rectangle {
                            height: 42px;
                            border-radius: 8px;
                            background: root.hotkey-available ? #12351f : #3a1d1d;
                            border-color: root.hotkey-available ? #1f7a3a : #7f1d1d;
                            border-width: 1px;
                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                Text {
                                    text: root.hotkey-error;
                                    color: root.hotkey-available ? #bbf7d0 : #fecaca;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        // Tip text
                        HorizontalLayout {
                            spacing: 6px;
                            padding-left: 4px;
                            Text {
                                text: "Pick a modifier and a key. Slots 1 & 2 are required; 3 & 4 are optional. Changes apply immediately.";
                                color: root.text-muted;
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                        }
                    }

                    
                    // Agent Page
                    if root.current-page == 3: VerticalBox {
                        alignment: start;
                        spacing: 20px;

                        // Page header
                        VerticalBox {
                            spacing: 4px;
                            Text {
                                text: "Agents";
                                font-size: 30px;
                                font-weight: 700;
                                color: root.text-primary;
                            }
                        }

                        // Section: Available Agents
                        VerticalBox {
                            spacing: 12px;
                            Text {
                                text: "AVAILABLE AGENTS";
                                font-size: 11px;
                                font-weight: 600;
                                color: root.text-muted;
                                letter-spacing: 1px;
                            }
                            
                            for agent in root.available-agents : Rectangle {
                                height: 64px;
                                background: agent-card-ta.has-hover ? root.hover-bg : root.card-bg;
                                border-radius: 8px;
                                border-color: agent-card-ta.has-hover ? root.accent : root.border-color;
                                border-width: 1px;
                                
                                animate background { duration: 150ms; easing: ease-in-out; }
                                animate border-color { duration: 150ms; easing: ease-in-out; }
                                
                                HorizontalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    spacing: 16px;
                                    
                                    // Avatar/Icon for Agent
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 36px;
                                            height: 36px;
                                            border-radius: 8px;
                                            clip: true;
                                            
                                            Image {
                                                source: root.agent-logo;
                                                width: 36px;
                                                height: 36px;
                                                image-fit: contain;
                                            }
                                        }
                                    }
                                    
                                    // Name and Goal
                                    VerticalLayout {
                                        alignment: center;
                                        spacing: 2px;
                                        Text {
                                            text: "@" + agent.name;
                                            color: root.text-primary;
                                            font-size: 14px;
                                            font-weight: 700;
                                        }
                                        Text {
                                            text: agent.goal;
                                            color: root.text-muted;
                                            font-size: 12px;
                                        }
                                    }
                                    
                                    Rectangle { horizontal-stretch: 1; }
                                    
                                    // Premium Message Pill Button
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            height: 28px;
                                            background: agent-card-ta.has-hover ? root.accent : transparent;
                                            border-radius: 12px;
                                            border-width: 1px;
                                            border-color: root.accent;
                                            
                                            animate background { duration: 150ms; easing: ease-in-out; }
                                            
                                            HorizontalLayout {
                                                padding-left: 12px;
                                                padding-right: 12px;
                                                alignment: center;
                                                
                                                Text {
                                                    text: "Message";
                                                    font-size: 11px;
                                                    font-weight: 700;
                                                    color: agent-card-ta.has-hover ? #1e1e1e : root.accent;
                                                    vertical-alignment: center;
                                                    horizontal-alignment: center;
                                                    
                                                    animate color { duration: 150ms; easing: ease-in-out; }
                                                }
                                            }
                                        }
                                    }
                                }
                                
                                agent-card-ta := TouchArea {
                                    clicked => {
                                        root.launch-agent(agent.id);
                                    }
                                }
                            }
                        }

                        // Section: API Settings
                        VerticalBox {
                            spacing: 12px;
                            Text {
                                text: "AI & ENDPOINT CONFIGURATION";
                                font-size: 11px;
                                font-weight: 600;
                                color: root.text-muted;
                                letter-spacing: 1px;
                            }
                            
                            Rectangle {
                                background: root.card-bg;
                                border-radius: 8px;
                                border-color: root.border-color;
                                border-width: 1px;
                                padding: 20px;
                                
                                VerticalBox {
                                    spacing: 16px;
                                    
                                    // API Key Row
                                    VerticalBox {
                                        spacing: 6px;
                                        Text { text: "API Key"; color: root.text-primary; font-size: 14px; font-weight: 600; }
                                        Text { text: "OpenCode Zen or DeepSeek API Key"; color: root.text-muted; font-size: 12px; }
                                        HorizontalBox {
                                            padding: 0;
                                            spacing: 8px;
                                            LineEdit {
                                                text: root.agent-api-key;
                                                placeholder-text: "sk-...";
                                                input-type: root.show-api-key ? InputType.text : InputType.password;
                                                edited(t) => {
                                                    root.agent-api-key = t;
                                                    root.save-settings();
                                                }
                                            }
                                            Button {
                                                text: root.show-api-key ? "Hide" : "Show";
                                                width: 60px;
                                                clicked => { root.show-api-key = !root.show-api-key; }
                                            }
                                        }
                                    }
                                    
                                    // Endpoint Row
                                    VerticalBox {
                                        spacing: 6px;
                                        Text { text: "API Endpoint"; color: root.text-primary; font-size: 14px; font-weight: 600; }
                                        Text { text: "Target endpoint URL for OpenAI-compatible chat completions"; color: root.text-muted; font-size: 12px; }
                                        LineEdit {
                                            text: root.agent-endpoint;
                                            placeholder-text: "https://api.deepseek.com/chat/completions";
                                            edited(t) => {
                                                root.agent-endpoint = t;
                                                root.save-settings();
                                            }
                                        }
                                    }
                                    
                                    // Model Row
                                    VerticalBox {
                                        spacing: 6px;
                                        Text { text: "Model Name"; color: root.text-primary; font-size: 14px; font-weight: 600; }
                                        Text { text: "The name of the model to request"; color: root.text-muted; font-size: 12px; }
                                        LineEdit {
                                            text: root.agent-model;
                                            placeholder-text: "deepseek-chat";
                                            edited(t) => {
                                                root.agent-model = t;
                                                root.save-settings();
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // Section: Safety
                        VerticalBox {
                            spacing: 12px;
                            Text {
                                text: "SAFETY & CONFIRMATIONS";
                                font-size: 11px;
                                font-weight: 600;
                                color: root.text-muted;
                                letter-spacing: 1px;
                            }
                            
                            Rectangle {
                                background: root.card-bg;
                                border-radius: 8px;
                                border-color: root.border-color;
                                border-width: 1px;
                                height: 64px;
                                HorizontalBox {
                                    padding-left: 20px;
                                    padding-right: 20px;
                                    spacing: 16px;
                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 36px;
                                            height: 36px;
                                            border-radius: 9px;
                                            background: #3b2a22;
                                            Rectangle {
                                                width: 22px;
                                                height: 22px;
                                                x: 7px;
                                                y: 7px;
                                                border-radius: 11px;
                                                background: #f97316;
                                                Text {
                                                    text: "!";
                                                    color: #1f130d;
                                                    font-size: 15px;
                                                    font-weight: 800;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }
                                    VerticalBox {
                                        alignment: center;
                                        spacing: 2px;
                                        Text { text: "Always approve agent actions"; color: root.text-primary; font-size: 14px; font-weight: 600; }
                                        Text { text: "Execute command line actions automatically without confirmation prompts"; color: root.text-muted; font-size: 12px; }
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    VerticalBox {
                                        alignment: center;
                                        ToggleSwitch {
                                            checked <=> root.agent-always-approve;
                                            toggled => {
                                                root.save-settings();
                                            }
                                        }
                                    }
                                }
                            }
                        }

                    }
                    
                    // Plugins Page
                    if root.current-page == 4: VerticalBox {
                        alignment: start;
                        spacing: 12px;
                        Text { text: "Plugins"; font-size: 30px; font-weight: 700; color: root.text-primary; }

                        VerticalBox {
                            spacing: 6px;
                            Text { text: "ENABLED PLUGINS"; font-size: 11px; font-weight: 600; color: root.text-muted; letter-spacing: 1px; }

                            Rectangle {
                                background: root.card-bg; border-radius: 8px; border-color: root.border-color; border-width: 1px;
                                height: root.show-circle-info ? 110px : 54px;
                                animate height { duration: 150ms; easing: ease-out; }
                                VerticalLayout {
                                    padding: 0;
                                    alignment: root.show-circle-info ? start : center;
                                    HorizontalBox {
                                        padding-left: 16px; padding-right: 16px; padding-top: 10px; padding-bottom: 10px; spacing: 12px;
                                        Text { text: "\u{e722}"; font-family: "Segoe MDL2 Assets"; font-size: 18px; color: root.accent; vertical-alignment: center; width: 24px; }
                                        VerticalLayout { alignment: center; spacing: 0; Text { text: "Circle to Search"; color: root.text-primary; font-size: 13px; font-weight: 600; } Text { text: "Select part of the screen and search it visually"; color: root.text-muted; font-size: 11px; } }
                                        Rectangle { horizontal-stretch: 1; }
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                width: 22px; height: 22px; border-radius: 11px;
                                                background: circle-i-touch.has-hover ? root.border-color : transparent;
                                                Text {
                                                    text: "\u{e946}";
                                                    font-family: "Segoe MDL2 Assets";
                                                    font-size: 14px;
                                                    color: root.show-circle-info ? root.accent : (circle-i-touch.has-hover ? root.text-primary : root.text-muted);
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                                circle-i-touch := TouchArea {
                                                    clicked => {
                                                        root.show-circle-info = !root.show-circle-info;
                                                    }
                                                }
                                            }
                                        }
                                        VerticalLayout { alignment: center; ToggleSwitch { checked <=> root.plugin-circle-search; toggled => { root.save-settings(); } } }
                                    }
                                    if root.show-circle-info : HorizontalBox {
                                        padding-left: 16px; padding-right: 16px; padding-bottom: 10px; spacing: 12px;
                                        Text {
                                            text: "Trigger: click the Lens button in the launcher search bar or press Alt + C. This freezes the screen so you can drag a selection box to search visually.";
                                            color: root.text-muted;
                                            font-size: 11px;
                                            wrap: word-wrap;
                                        }
                                    }
                                }
                            }
                            Rectangle {
                                background: root.card-bg; border-radius: 8px; border-color: root.border-color; border-width: 1px;
                                height: root.show-text-info ? 110px : 54px;
                                animate height { duration: 150ms; easing: ease-out; }
                                VerticalLayout {
                                    padding: 0;
                                    alignment: root.show-text-info ? start : center;
                                    HorizontalBox {
                                        padding-left: 16px; padding-right: 16px; padding-top: 10px; padding-bottom: 10px; spacing: 12px;
                                        Text { text: "\u{e8d2}"; font-family: "Segoe MDL2 Assets"; font-size: 18px; color: root.accent; vertical-alignment: center; width: 24px; }
                                        VerticalLayout { alignment: center; spacing: 0; Text { text: "Text Expansions"; color: root.text-primary; font-size: 13px; font-weight: 600; } Text { text: "Reusable snippets triggered from launcher search"; color: root.text-muted; font-size: 11px; } }
                                        Rectangle { horizontal-stretch: 1; }
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                width: 22px; height: 22px; border-radius: 11px;
                                                background: snip-i-touch.has-hover ? root.border-color : transparent;
                                                Text {
                                                    text: "\u{e946}";
                                                    font-family: "Segoe MDL2 Assets";
                                                    font-size: 14px;
                                                    color: root.show-text-info ? root.accent : (snip-i-touch.has-hover ? root.text-primary : root.text-muted);
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                                snip-i-touch := TouchArea {
                                                    clicked => {
                                                        root.show-text-info = !root.show-text-info;
                                                    }
                                                }
                                            }
                                        }
                                        VerticalLayout { alignment: center; ToggleSwitch { checked <=> root.plugin-text-expansions; toggled => { root.save-settings(); } } }
                                    }
                                    if root.show-text-info : HorizontalBox {
                                        padding-left: 16px; padding-right: 16px; padding-bottom: 10px; spacing: 12px;
                                        Text {
                                            text: "💡 Trigger: Type your custom expansion keyword (or 'snip:' to browse all) in the launcher and press Enter. The expansion text is immediately copied and pasted.";
                                            color: root.text-muted;
                                            font-size: 11px;
                                            wrap: word-wrap;
                                        }
                                    }
                                }
                            }
                            Rectangle {
                                background: root.card-bg; border-radius: 8px; border-color: root.border-color; border-width: 1px;
                                height: root.show-color-info ? 110px : 54px;
                                animate height { duration: 150ms; easing: ease-out; }
                                VerticalLayout {
                                    padding: 0;
                                    alignment: root.show-color-info ? start : center;
                                    HorizontalBox {
                                        padding-left: 16px; padding-right: 16px; padding-top: 10px; padding-bottom: 10px; spacing: 12px;
                                        Text { text: "\u{e790}"; font-family: "Segoe MDL2 Assets"; font-size: 18px; color: root.accent; vertical-alignment: center; width: 24px; }
                                        VerticalLayout { alignment: center; spacing: 0; Text { text: "Color Picker"; color: root.text-primary; font-size: 13px; font-weight: 600; } Text { text: "Pick a pixel color and copy its hex value"; color: root.text-muted; font-size: 11px; } }
                                        Rectangle { horizontal-stretch: 1; }
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                width: 22px; height: 22px; border-radius: 11px;
                                                background: color-i-touch.has-hover ? root.border-color : transparent;
                                                Text {
                                                    text: "\u{e946}";
                                                    font-family: "Segoe MDL2 Assets";
                                                    font-size: 14px;
                                                    color: root.show-color-info ? root.accent : (color-i-touch.has-hover ? root.text-primary : root.text-muted);
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                                color-i-touch := TouchArea {
                                                    clicked => {
                                                        root.show-color-info = !root.show-color-info;
                                                    }
                                                }
                                            }
                                        }
                                        VerticalLayout { alignment: center; ToggleSwitch { checked <=> root.plugin-color-picker; toggled => { root.save-settings(); } } }
                                    }
                                    if root.show-color-info : HorizontalBox {
                                        padding-left: 16px; padding-right: 16px; padding-bottom: 10px; spacing: 12px;
                                        Text {
                                            text: "💡 Trigger: Type 'color' or 'color picker' in the launcher and press Enter. This launches a pixel magnifier tool; clicking copies the selected color's hex code.";
                                            color: root.text-muted;
                                            font-size: 11px;
                                            wrap: word-wrap;
                                        }
                                    }
                                }
                            }
                            Rectangle {
                                background: root.card-bg; border-radius: 8px; border-color: root.border-color; border-width: 1px;
                                height: root.show-calc-info ? 110px : 54px;
                                animate height { duration: 150ms; easing: ease-out; }
                                VerticalLayout {
                                    padding: 0;
                                    alignment: root.show-calc-info ? start : center;
                                    HorizontalBox {
                                        padding-left: 16px; padding-right: 16px; padding-top: 10px; padding-bottom: 10px; spacing: 12px;
                                        Text { text: "\u{e8ef}"; font-family: "Segoe MDL2 Assets"; font-size: 18px; color: root.accent; vertical-alignment: center; width: 24px; }
                                        VerticalLayout { alignment: center; spacing: 0; Text { text: "Calculator"; color: root.text-primary; font-size: 13px; font-weight: 600; } Text { text: "Inline math and unit conversion results"; color: root.text-muted; font-size: 11px; } }
                                        Rectangle { horizontal-stretch: 1; }
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                width: 22px; height: 22px; border-radius: 11px;
                                                background: calc-i-touch.has-hover ? root.border-color : transparent;
                                                Text {
                                                    text: "\u{e946}";
                                                    font-family: "Segoe MDL2 Assets";
                                                    font-size: 14px;
                                                    color: root.show-calc-info ? root.accent : (calc-i-touch.has-hover ? root.text-primary : root.text-muted);
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                                calc-i-touch := TouchArea {
                                                    clicked => {
                                                        root.show-calc-info = !root.show-calc-info;
                                                    }
                                                }
                                            }
                                        }
                                        VerticalLayout { alignment: center; ToggleSwitch { checked <=> root.plugin-calculator; toggled => { root.save-settings(); } } }
                                    }
                                    if root.show-calc-info : HorizontalBox {
                                        padding-left: 16px; padding-right: 16px; padding-bottom: 10px; spacing: 12px;
                                        Text {
                                            text: "💡 Trigger: Type any formula or math equation directly in the search bar (e.g. 'sqrt(16) * 12' or '15% of 350'). The parsed result is shown inline immediately.";
                                            color: root.text-muted;
                                            font-size: 11px;
                                            wrap: word-wrap;
                                        }
                                    }
                                }
                            }
                            Rectangle {
                                background: root.card-bg; border-radius: 8px; border-color: root.border-color; border-width: 1px;
                                height: root.show-git-info ? 110px : 54px;
                                animate height { duration: 150ms; easing: ease-out; }
                                VerticalLayout {
                                    padding: 0;
                                    alignment: root.show-git-info ? start : center;
                                    HorizontalBox {
                                        padding-left: 16px; padding-right: 16px; padding-top: 10px; padding-bottom: 10px; spacing: 12px;
                                        Text { text: "\u{e8ee}"; font-family: "Segoe MDL2 Assets"; font-size: 18px; color: root.accent; vertical-alignment: center; width: 24px; }
                                        VerticalLayout { alignment: center; spacing: 0; Text { text: "Git Commits"; color: root.text-primary; font-size: 13px; font-weight: 600; } Text { text: "Recent repository commits in search and filters"; color: root.text-muted; font-size: 11px; } }
                                        Rectangle { horizontal-stretch: 1; }
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                width: 22px; height: 22px; border-radius: 11px;
                                                background: git-i-touch.has-hover ? root.border-color : transparent;
                                                Text {
                                                    text: "\u{e946}";
                                                    font-family: "Segoe MDL2 Assets";
                                                    font-size: 14px;
                                                    color: root.show-git-info ? root.accent : (git-i-touch.has-hover ? root.text-primary : root.text-muted);
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                                git-i-touch := TouchArea {
                                                    clicked => {
                                                        root.show-git-info = !root.show-git-info;
                                                    }
                                                }
                                            }
                                        }
                                        VerticalLayout { alignment: center; ToggleSwitch { checked <=> root.plugin-git-commits; toggled => { root.save-settings(); } } }
                                    }
                                    if root.show-git-info : HorizontalBox {
                                        padding-left: 16px; padding-right: 16px; padding-bottom: 10px; spacing: 12px;
                                        Text {
                                            text: "Trigger: type 'commits:' or search commit text. Turning this off removes Git commit results, the home shortcut, and related filter counts until re-enabled.";
                                            color: root.text-muted;
                                            font-size: 11px;
                                            wrap: word-wrap;
                                        }
                                    }
                                }
                            }
                            Rectangle {
                                background: root.card-bg; border-radius: 8px; border-color: root.border-color; border-width: 1px;
                                height: 54px;
                                HorizontalBox {
                                    padding-left: 16px; padding-right: 16px; padding-top: 10px; padding-bottom: 10px; spacing: 12px;
                                    Text { text: "\u{e8a5}"; font-family: "Segoe MDL2 Assets"; font-size: 18px; color: root.accent; vertical-alignment: center; width: 24px; }
                                    VerticalLayout { alignment: center; spacing: 0; Text { text: "Read Clipboard Image Text"; color: root.text-primary; font-size: 13px; font-weight: 600; } Text { text: "Show the manual image text action on the launcher home screen"; color: root.text-muted; font-size: 11px; } }
                                    Rectangle { horizontal-stretch: 1; }
                                    VerticalLayout { alignment: center; ToggleSwitch { checked <=> root.show-clipboard-image-text-action; toggled => { root.save-settings(); } } }
                                }
                            }
                        }
                    }

                    // Config Page
                    if root.current-page == 5: VerticalBox {
                        alignment: start;
                        spacing: 22px;
                        Text { text: "Config"; font-size: 34px; font-weight: 700; color: root.text-primary; }

                        VerticalBox {
                            spacing: 14px;
                            HorizontalBox {
                                Text { text: "TEXT EXPANSIONS"; font-size: 12px; font-weight: 700; color: root.text-muted; letter-spacing: 1px; }
                                Rectangle { horizontal-stretch: 1; }
                                Text { text: root.snippets.length + " saved"; font-size: 12px; color: root.text-muted; }
                            }
                            Rectangle {
                                background: root.card-bg; border-radius: 10px; border-color: root.border-color; border-width: 1px;
                                VerticalBox {
                                    padding: 18px; spacing: 14px;
                                    VerticalBox {
                                        spacing: 4px;
                                        Text { text: "Add expansion"; color: root.text-primary; font-size: 16px; font-weight: 700; }
                                        Text { text: "Type the trigger in ProtonSearch, press Enter, and the saved text is pasted into the previous app."; color: root.text-muted; font-size: 12px; }
                                    }
                                    VerticalBox {
                                        padding: 0; spacing: 12px;
                                        HorizontalBox {
                                            padding: 0; spacing: 10px;
                                            HorizontalBox {
                                                padding: 0; spacing: 12px; horizontal-stretch: 3;
                                                Text { text: "Name"; color: root.text-muted; font-size: 12px; font-weight: 600; width: 110px; vertical-alignment: center; }
                                                Rectangle {
                                                    height: 34px;
                                                    border-width: 1.5px;
                                                    border-color: root.snippet-name-error ? #ff4d4d : transparent;
                                                    border-radius: 4px;
                                                    LineEdit {
                                                        width: 100%; height: 100%;
                                                        text <=> root.snippet-name; placeholder-text: "Work email";
                                                        edited => { root.snippet-name-error = false; }
                                                    }
                                                }
                                            }
                                            HorizontalBox {
                                                padding: 0; spacing: 12px; horizontal-stretch: 1;
                                                Text { text: "Trigger"; color: root.text-muted; font-size: 12px; font-weight: 600; vertical-alignment: center; }
                                                LineEdit { text <=> root.snippet-keyword; placeholder-text: "!email"; height: 34px; }
                                            }
                                        }
                                        HorizontalBox {
                                            padding: 0; spacing: 12px;
                                            Text { text: "Expansion text"; color: root.text-muted; font-size: 12px; font-weight: 600; width: 110px; vertical-alignment: center; }
                                            Rectangle {
                                                height: 40px;
                                                border-width: 1.5px;
                                                border-color: root.snippet-content-error ? #ff4d4d : transparent;
                                                border-radius: 4px;
                                                LineEdit {
                                                    width: 100%; height: 100%;
                                                    text <=> root.snippet-content; placeholder-text: "Text to paste";
                                                    edited => { root.snippet-content-error = false; }
                                                }
                                            }
                                        }
                                    }
                                    HorizontalBox {
                                        padding: 0;
                                        Text { text: "Name and expansion text are required. Empty trigger uses the name."; color: root.text-muted; font-size: 12px; vertical-alignment: center; }
                                        Rectangle { horizontal-stretch: 1; }
                                        VerticalLayout {
                                            alignment: center;
                                            Button {
                                                text: "Add expansion";
                                                clicked => {
                                                    root.snippet-name-error = root.snippet-name == "";
                                                    root.snippet-content-error = root.snippet-content == "";
                                                    if (!root.snippet-name-error && !root.snippet-content-error) {
                                                        root.add-snippet();
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                            for snippet[i] in root.snippets: Rectangle {
                                background: root.card-bg; border-radius: 10px; border-color: root.border-color; border-width: 1px;
                                HorizontalBox {
                                    padding-top: 14px; padding-bottom: 14px;
                                    padding-left: 18px; padding-right: 16px;
                                    spacing: 16px;
                                    Rectangle {
                                        width: 96px; height: 30px; border-radius: 8px; background: root.hover-bg; border-color: root.accent; border-width: 1px;
                                        Text { text: snippet.keyword; color: root.accent; font-size: 13px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                    Text {
                                        text: snippet.name;
                                        color: root.text-primary;
                                        font-size: 15px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                        visible: snippet.name != snippet.keyword;
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    Text { text: snippet.content; color: root.accent; font-size: 14px; font-weight: 600; overflow: elide; vertical-alignment: center; max-width: 300px; horizontal-alignment: right; }
                                    VerticalLayout {
                                        alignment: center;
                                        Button { text: "Delete"; clicked => { root.delete-snippet(snippet.id); } }
                                    }
                                }
                            }
                        }
                    }

                    // Database Page
                    if root.current-page == 6: VerticalBox {
                        alignment: start;
                        spacing: 20px;

                        // Page header
                        VerticalBox {
                            spacing: 4px;
                            Text {
                                text: "Database";
                                font-size: 30px;
                                font-weight: 700;
                                color: root.text-primary;
                            }
                        }

                        // Section: Status & Statistics
                        VerticalBox {
                            spacing: 12px;
                            Text {
                                text: "STATUS & STATISTICS";
                                font-size: 11px;
                                font-weight: 600;
                                color: root.text-muted;
                                letter-spacing: 1px;
                            }
                            
                            Rectangle {
                                background: root.card-bg;
                                border-radius: 8px;
                                border-color: root.border-color;
                                border-width: 1px;
                                
                                VerticalBox {
                                    padding: 16px;
                                    spacing: 16px;
                                    
                                    // Row 1: Status
                                    HorizontalBox {
                                        padding: 0;
                                        spacing: 12px;
                                        alignment: start;
                                        
                                        VerticalBox {
                                            padding: 0;
                                            spacing: 4px;
                                            Text {
                                                text: "Index Status";
                                                color: root.text-muted;
                                                font-size: 12px;
                                                font-weight: 500;
                                            }
                                            HorizontalBox {
                                                padding: 0;
                                                spacing: 8px;
                                                alignment: start;
                                                
                                                // Live indicator light
                                                Rectangle {
                                                    width: 10px;
                                                    height: 10px;
                                                    border-radius: 5px;
                                                    background: root.db-is-indexing ? #007acc : #4caf50;
                                                }
                                                
                                                Text {
                                                    text: root.db-is-indexing ? root.db-status : (root.db-status == "Idle" ? "Ready (Up to date)" : root.db-status);
                                                    color: root.db-is-indexing ? #007acc : root.text-primary;
                                                    font-size: 14px;
                                                    font-weight: 600;
                                                }
                                            }
                                        }
                                    }
                                    
                                    // Separator line
                                    Rectangle {
                                        height: 1px;
                                        background: root.border-color;
                                    }
                                    
                                    // Row 2: Statistics
                                    HorizontalBox {
                                        padding: 0;
                                        spacing: 32px;
                                        
                                        VerticalBox {
                                            padding: 0;
                                            spacing: 4px;
                                            Text {
                                                text: "Indexed Items";
                                                color: root.text-muted;
                                                font-size: 12px;
                                                font-weight: 500;
                                            }
                                            Text {
                                                text: "" + root.db-file-count;
                                                color: root.text-primary;
                                                font-size: 20px;
                                                font-weight: 700;
                                            }
                                        }
                                        
                                        VerticalBox {
                                            padding: 0;
                                            spacing: 4px;
                                            Text {
                                                text: "Last Rebuild Completed";
                                                color: root.text-muted;
                                                font-size: 12px;
                                                font-weight: 500;
                                            }
                                            Text {
                                                text: root.db-last-indexed;
                                                color: root.text-primary;
                                                font-size: 14px;
                                                font-weight: 600;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // Section: Folders
                        VerticalBox {
                            spacing: 12px;
                            Text {
                                text: "INDEXED DIRECTORIES";
                                font-size: 11px;
                                font-weight: 600;
                                color: root.text-muted;
                                letter-spacing: 1px;
                            }
                            
                            // Add/Rebuild Actions
                            HorizontalBox {
                                padding: 0;
                                spacing: 10px;
                                Button {
                                    text: "Add Directory...";
                                    clicked => { root.add-folder(); }
                                }
                                Button {
                                    text: "Rebuild Index Now";
                                    enabled: !root.db-is-indexing;
                                    clicked => { root.rebuild-index(); }
                                }
                            }
                            
                            // List of directories
                            Rectangle {
                                background: root.card-bg;
                                border-radius: 8px;
                                border-color: root.border-color;
                                border-width: 1px;
                                
                                VerticalBox {
                                    padding: 12px;
                                    spacing: 8px;
                                    if root.db-folders.length == 0: Text {
                                        text: "No indexed directories configured";
                                        color: root.text-muted;
                                        font-size: 13px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        height: 40px;
                                    }
                                    for folder[idx] in root.db-folders: Rectangle {
                                        background: root.hover-bg;
                                        border-radius: 6px;
                                        height: 38px;
                                        HorizontalBox {
                                            padding-left: 12px;
                                            padding-right: 12px;
                                            Text {
                                                text: folder;
                                                color: root.text-primary;
                                                font-size: 13px;
                                                vertical-alignment: center;
                                            }
                                            Rectangle { horizontal-stretch: 1; }
                                            Button {
                                                text: "Remove";
                                                width: 70px;
                                                clicked => {
                                                    root.remove-folder(idx);
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // Section: Ignored folders
                        VerticalBox {
                            spacing: 12px;
                            Text {
                                text: "IGNORED FOLDER NAMES";
                                font-size: 11px;
                                font-weight: 600;
                                color: root.text-muted;
                                letter-spacing: 1px;
                            }

                            Rectangle {
                                background: root.card-bg;
                                border-radius: 8px;
                                border-color: root.border-color;
                                border-width: 1px;

                                VerticalBox {
                                    padding: 12px;
                                    spacing: 8px;

                                    HorizontalBox {
                                        spacing: 8px;
                                        LineEdit {
                                            text <=> root.db-ignore-input;
                                            placeholder-text: "node_modules or .angular";
                                            height: 34px;
                                        }
                                        Button {
                                            text: "Add";
                                            width: 72px;
                                            clicked => { root.add-ignored-folder(); }
                                        }
                                    }

                                    Text {
                                        text: "Names match folders anywhere under indexed directories.";
                                        color: root.text-muted;
                                        font-size: 12px;
                                    }

                                    if root.db-ignored-folders.length == 0: Text {
                                        text: "No ignored folder names configured";
                                        color: root.text-muted;
                                        font-size: 13px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        height: 32px;
                                    }
                                    for folder[idx] in root.db-ignored-folders: Rectangle {
                                        background: root.hover-bg;
                                        border-radius: 6px;
                                        height: 38px;
                                        HorizontalBox {
                                            padding-left: 12px;
                                            padding-right: 12px;
                                            Text {
                                                text: folder;
                                                color: root.text-primary;
                                                font-size: 13px;
                                                vertical-alignment: center;
                                            }
                                            Rectangle { horizontal-stretch: 1; }
                                            Button {
                                                text: "Remove";
                                                width: 70px;
                                                clicked => {
                                                    root.remove-ignored-folder(idx);
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                    
                    // About Page
                    if root.current-page == 7: VerticalBox {
                        alignment: start;
                        spacing: 24px;
                        Text { text: "About"; font-size: 30px; font-weight: 700; color: root.text-primary; }
                        
                        // Card 1: Version & Sponsors
                        Rectangle {
                            background: root.card-bg;
                            border-radius: 8px;
                            border-color: root.border-color;
                            border-width: 1px;
                            height: 64px;
                            HorizontalLayout {
                                padding-left: 20px;
                                padding-right: 20px;
                                spacing: 16px;
                                
                                // Left side
                                HorizontalLayout {
                                    alignment: start;
                                    spacing: 12px;
                                    VerticalLayout {
                                        alignment: center;
                                        spacing: 2px;
                                        Text { text: root.app-version; font-size: 18px; font-weight: 600; color: root.text-primary; }
                                        Text { text: "Version"; font-size: 13px; color: root.text-muted; }
                                    }
                                }
                                
                                Rectangle { horizontal-stretch: 1; }
                                
                                // Right side
                                HorizontalLayout {
                                    alignment: end;
                                    spacing: 12px;
                                    VerticalLayout {
                                        alignment: center;
                                        Button {
                                             width: 180px;
                                             text: root.update-status == "idle" ? "Check for Updates" :
                                                   root.update-status == "checking" ? "Checking..." :
                                                   root.update-status == "available" ? "Download Update (v" + root.update-version + ")" :
                                                   root.update-status == "downloading" ? "Downloading... (" + root.update-progress + "%)" :
                                                   root.update-status == "ready" ? "Install Update" :
                                                   root.update-status == "uptodate" ? "No Update Available" :
                                                   "Error - Retry";
                                             enabled: root.update-status == "idle" ||
                                                      root.update-status == "available" ||
                                                      root.update-status == "ready" ||
                                                      root.update-status == "error";
                                             clicked => {
                                                 if (root.update-status == "idle" || root.update-status == "error") {
                                                     root.check-for-updates();
                                                 } else if (root.update-status == "available") {
                                                     root.download-update();
                                                 } else if (root.update-status == "ready") {
                                                     root.install-update();
                                                 }
                                             }
                                        }
                                    }
                                    VerticalLayout {
                                        alignment: center;
                                        Button {
                                            width: 180px;
                                            text: "Become a Sponsor";
                                            primary: true;
                                            clicked => { root.open-url("https://github.com/sponsors/PranshulSoni"); }
                                        }
                                    }
                                }
                            }
                        }

                        // Card 2: Links
                        Rectangle {
                            background: root.card-bg;
                            border-radius: 8px;
                            border-color: root.border-color;
                            border-width: 1px;
                            height: 64px;
                            HorizontalLayout {
                                padding-left: 20px;
                                padding-right: 20px;
                                spacing: 16px;
                                
                                // Left side
                                HorizontalLayout {
                                    alignment: start;
                                    spacing: 12px;
                                    VerticalLayout {
                                        alignment: center;
                                        Text { text: "Website"; font-size: 18px; font-weight: 600; color: root.text-primary; }
                                    }
                                }
                                
                                Rectangle { horizontal-stretch: 1; }
                                
                                // Right side
                                HorizontalLayout {
                                    alignment: end;
                                    spacing: 16px;
                                    
                                    VerticalLayout {
                                        alignment: center;
                                        Text {
                                            text: "Website";
                                            color: website-ta.has-hover ? #4daaf8 : #1d90f3;
                                            font-size: 13px;
                                            website-ta := TouchArea {
                                                clicked => { root.open-url("https://protonsearch-windows.vercel.app/"); }
                                            }
                                        }
                                    }
                                    
                                    VerticalLayout {
                                        alignment: center;
                                        Text {
                                            text: "GitHub";
                                            color: github-ta.has-hover ? #4daaf8 : #1d90f3;
                                            font-size: 13px;
                                            github-ta := TouchArea {
                                                clicked => { root.open-url("https://github.com/PranshulSoni/protonsearch"); }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }


                }
            }
        }
    }
}

}
