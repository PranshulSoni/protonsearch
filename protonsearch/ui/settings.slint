    in-out property <bool> plugin-circle-search;
    in-out property <bool> plugin-text-expansions;
    in-out property <bool> plugin-color-picker;
    in-out property <bool> plugin-calculator;
    in-out property <bool> plugin-git-commits;
    in-out property <bool> show-clipboard-image-text-action;
    in-out property <string> snippet-name;
    in-out property <string> snippet-keyword;
    in-out property <string> snippet-content;
    in-out property <image> desktop-wallpaper;
    in-out property <bool> has-desktop-wallpaper: false;
    in-out property <bool> snippet-name-error: false;
    in-out property <bool> snippet-content-error: false;

    property <bool> edit-panel-expanded: false;
    
    // Plugin Info Expand states
    in-out property <bool> show-circle-info: false;
    in-out property <bool> show-text-info: false;
    in-out property <bool> show-color-info: false;
    in-out property <bool> show-calc-info: false;
    in-out property <bool> show-git-info: false;
    
    // Callbacks to Rust
    callback save-settings();
    callback add-snippet();
    callback delete-snippet(int);
    // Re-assemble + validate the hotkey from the four dropdown slots, then apply/save it.
    callback apply-hotkey();
    callback open-url(string);

    // Hotkey dropdown models + selected values (built in Rust).
    in-out property <[string]> slot1-model;
    in-out property <[string]> slot2-model;
    in-out property <[string]> slot34-model;
    in-out property <string> slot1-val;
    in-out property <string> slot2-val;
    in-out property <string> slot3-val: "â€”";
    in-out property <string> slot4-val: "â€”";

    // Agent settings properties
    in-out property <string> agent-api-key;
    in-out property <string> agent-endpoint;
    in-out property <string> agent-model;
    in-out property <bool> agent-always-approve;
    in-out property <image> agent-logo: @image-url("../../icons/AgentLogo.png");

    // Database settings properties
    in-out property <string> db-last-indexed;
    in-out property <int> db-file-count;
    in-out property <string> db-status;
    in-out property <bool> db-is-indexing;
    in-out property <[string]> db-folders;
    in-out property <[string]> db-ignored-folders;
    in-out property <string> db-ignore-input;

    // Database callbacks
    callback add-folder();
    callback remove-folder(int);
    callback add-ignored-folder();
    callback remove-ignored-folder(int);
    callback rebuild-index();

    // Update settings properties
    in-out property <string> update-status: "idle"; // "idle", "checking", "available", "downloading", "ready", "uptodate", "error"
    in-out property <string> update-version: "";
    in-out property <int> update-progress: 0;
    in-out property <string> app-version: "1.1.0";

    // Update callbacks
    callback check-for-updates();
    callback download-update();
    callback install-update();




    
    property <int> current-page: 0;
    property <bool> show-api-key: false;

    
    // Theme Tokens
    property <bool> is-light: false; // Locked to dark mode for settings app
    property <color> bg-color: is-light ? #FAFAFA : #202020;
    property <color> sidebar-bg: is-light ? #F0F0F0 : #151515;
    property <color> card-bg: is-light ? #FFFFFF : #2b2b2b;
    
