                                        spacing: 2px;
                                        Text { text: "Hide on lose focus"; color: root.text-primary; font-size: 14px; font-weight: 600; }
                                        Text { text: "Dismiss launcher when it loses keyboard focus"; color: root.text-muted; font-size: 12px; }
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    VerticalBox {
                                        alignment: center;
                                        ToggleSwitch {
                                            checked <=> root.hide-on-lose-focus;
                                            toggled => {
                                                root.save-settings();
                                            }
                                        }
                                    }
                                }
                            }

                            Rectangle { height: 6px; }

                            // Show taskbar when ProtonSearch is opened row
                            Rectangle {
                                background: root.card-bg;
                                border-radius: 8px;
                                border-color: root.border-color;
                                border-width: 1px;
                                height: 64px;
                                HorizontalBox {
                                    padding-left: 20px;
                                    padding-right: 20px;
                                    spacing: 16px;

                                    VerticalBox {
                                        alignment: center;
                                        spacing: 2px;
                                        Text { text: "Show taskbar when ProtonSearch is opened"; color: root.text-primary; font-size: 14px; font-weight: 600; }
                                        Text { text: "Temporarily show taskbar when ProtonSearch is opened, useful for auto-hidden taskbars"; color: root.text-muted; font-size: 12px; }
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    VerticalBox {
                                        alignment: center;
                                        ToggleSwitch {
                                            checked <=> root.show-taskbar;
                                            toggled => {
