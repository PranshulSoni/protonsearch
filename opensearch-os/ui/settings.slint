import { Button, VerticalBox, HorizontalBox, CheckBox, ComboBox, LineEdit, StandardListView, TabWidget, Slider, ScrollView, Palette } from "std-widgets.slint";

export component ToggleSwitch inherits Rectangle {
    in-out property <bool> checked;
    callback toggled;

    width: 44px;
    height: 20px;
    border-radius: 10px;
    background: checked ? #1d90f3 : #1a1a1a;
    border-width: 1px;
    border-color: checked ? #1d90f3 : #8a8a8a;

    animate background { duration: 150ms; easing: ease-in-out; }
    animate border-color { duration: 150ms; easing: ease-in-out; }

    Rectangle {
        x: checked ? parent.width - self.width - 4px : 4px;
        y: (parent.height - self.height) / 2;
        width: 12px;
        height: 12px;
        border-radius: 6px;
        background: checked ? #1a1a1a : #8a8a8a;

        animate x { duration: 150ms; easing: ease-in-out; }
        animate background { duration: 150ms; easing: ease-in-out; }
    }

    TouchArea {
        clicked => {
            checked = !checked;
            toggled();
        }
    }
}

export component CustomDropdown inherits Rectangle {
    in-out property <[string]> model;
    in-out property <int> current-index: 0;
    in-out property <string> selected-value: model[current-index];
    callback selected(string);

    property <bool> is-open: false;

    width: 220px;
    height: 32px;
    background: #2b2b2b;
    border-radius: 6px;
    border-width: 1px;
    border-color: #3f3f3f;

    HorizontalBox {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;
        alignment: center;

        Text {
            text: model[current-index];
            color: #ffffff;
            font-size: 13px;
            vertical-alignment: center;
        }

        Rectangle { horizontal-stretch: 1; }

        Text {
            text: is-open ? "▲" : "▼";
            color: #aaaaaa;
            font-size: 8px;
            vertical-alignment: center;
        }
    }

    TouchArea {
        clicked => {
            is-open = !is-open;
        }
    }

    // Popup list container
    if is-open : Rectangle {
        y: 36px;
        width: parent.width;
        height: model.length * 30px + 10px;
        background: #2b2b2b;
        border-radius: 6px;
        border-width: 1px;
        border-color: #3f3f3f;
        z: 100; // Draw on top of everything!

        VerticalBox {
            padding: 4px;
            spacing: 2px;
            for item[idx] in model : Rectangle {
                height: 26px;
                background: current-index == idx ? #1d90f3 : (item-ta.has-hover ? #353535 : transparent);
                border-radius: 4px;
                
                HorizontalBox {
                    padding-left: 8px;
                    alignment: center;
                    Text {
                        text: item;
                        color: #ffffff;
                        font-size: 13px;
                        vertical-alignment: center;
                    }
                }

                item-ta := TouchArea {
                    clicked => {
                        current-index = idx;
                        selected-value = item;
                        is-open = false;
                        selected(item);
                    }
                }
            }
        }
    }
}

export component SettingsWindow inherits Window {
    title: "Settings";
    min-width: 950px;
    min-height: 600px;
    preferred-width: 950px;
    preferred-height: 600px;
    
    // Properties to bind to Rust
    in-out property <bool> run-on-startup;
    in-out property <bool> hide-on-lose-focus;
    in-out property <bool> show-taskbar;
    in-out property <string> window-location;
    in-out property <string> theme-mode;
    in-out property <string> global-hotkey;
    in-out property <string> voice-hotkey;
    in-out property <string> hotkey-error;
    
    in-out property <int> window-width;
    in-out property <int> item-height;
    in-out property <int> search-bar-height;
    in-out property <string> query-font-family;
    in-out property <string> query-font-weight;
    in-out property <int> query-font-size;
    in-out property <string> result-title-font-family;
    in-out property <string> result-title-font-weight;
    in-out property <int> result-title-font-size;
    in-out property <string> result-subtitle-font-family;
    in-out property <string> result-subtitle-font-weight;
    in-out property <int> result-subtitle-font-size;
    in-out property <bool> show-placeholder;
    in-out property <image> desktop-wallpaper;
    in-out property <bool> has-desktop-wallpaper: false;

    property <bool> edit-panel-expanded: false;
    
    // Callbacks to Rust
    callback save-settings();
    callback format-hotkey(string, bool, bool, bool, bool) -> string;
    callback validate-hotkey(string) -> string;
    callback set-hotkey-recording(bool);
    
    // Agent settings properties
    in-out property <string> agent-api-key;
    in-out property <string> agent-endpoint;
    in-out property <string> agent-model;
    in-out property <bool> agent-always-approve;

    // Database settings properties
    in-out property <string> db-last-indexed;
    in-out property <int> db-file-count;
    in-out property <string> db-status;
    in-out property <bool> db-is-indexing;
    in-out property <[string]> db-folders;

    // Database callbacks
    callback add-folder();
    callback remove-folder(int);
    callback rebuild-index();


    
    property <int> current-page: 0;
    property <bool> recording-hotkey: false;
    property <string> previous-hotkey: "";
    property <bool> show-api-key: false;

    
    // Theme Tokens
    property <bool> is-light: false; // Locked to dark mode for settings app
    property <color> bg-color: is-light ? #FAFAFA : #1e1e1e;
    property <color> sidebar-bg: is-light ? #F0F0F0 : #252525;
    property <color> card-bg: is-light ? #FFFFFF : #2b2b2b;
    
    property <color> text-primary: is-light ? #111111 : #ffffff;
    property <color> text-secondary: is-light ? #555555 : #cccccc;
    property <color> text-muted: is-light ? #777777 : #aaaaaa;
    
    property <color> hover-bg: is-light ? #E5E5E5 : #2f2f2f;
    property <color> active-bg: is-light ? #D5D5D5 : #3a3a3a;
    property <color> border-color: is-light ? #EAEAEA : #333333;

    // Accent color
    property <color> accent: #60a5fa;

    background: root.bg-color;

    HorizontalBox {
        padding: 0;
        spacing: 0;
        
        // ── Sidebar ──────────────────────────────────────────────
        Rectangle {
            width: 230px;
            background: root.sidebar-bg;

            VerticalBox {
                padding: 0px;
                spacing: 0px;

                // App identity block
                Rectangle {
                    height: 80px;
                    background: transparent;
                    HorizontalBox {
                        padding-left: 20px;
                        padding-right: 20px;
                        spacing: 12px;
                        // App icon pill
                        Rectangle {
                            width: 36px;
                            height: 36px;
                            border-radius: 10px;
                            background: root.accent;
                            Text {
                                text: "⌖";
                                color: #ffffff;
                                font-size: 20px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        VerticalBox {
                            alignment: center;
                            spacing: 2px;
                            Text {
                                text: "OmniSearch";
                                font-size: 15px;
                                font-weight: 700;
                                color: root.text-primary;
                            }
                            Text {
                                text: "Settings";
                                font-size: 11px;
                                color: root.text-muted;
                            }
                        }
                    }
                }

                // Thin divider
                Rectangle { height: 1px; background: root.border-color; }

                // Nav items
                Rectangle { height: 12px; }

                // ── Nav item helper component would be ideal but Slint doesn't allow
                // inline components, so we expand each one.

                // General
                nav-general := Rectangle {
                    height: 42px;
                    border-radius: 8px;
                    x: 8px;
                    width: parent.width - 16px;
                    background: root.current-page == 0 ? #353535 : (ta-general.has-hover ? root.hover-bg : transparent);
                    animate background { duration: 120ms; }
                    // Left accent bar
                    Rectangle {
                        x: 0px;
                        y: 8px;
                        width: 3px;
                        height: parent.height - 16px;
                        border-radius: 2px;
                        background: root.current-page == 0 ? root.accent : transparent;
                    }
                    HorizontalBox {
                        padding-left: 16px;
                        spacing: 10px;
                        Text {
                            text: "⚙";
                            font-size: 15px;
                            color: root.current-page == 0 ? root.text-primary : root.text-muted;
                            vertical-alignment: center;
                            width: 18px;
                        }
                        Text {
                            text: "General";
                            font-size: 14px;
                            font-weight: root.current-page == 0 ? 600 : 400;
                            color: root.current-page == 0 ? root.text-primary : root.text-secondary;
                            vertical-alignment: center;
                        }
                    }
                    ta-general := TouchArea { clicked => { root.current-page = 0; } }
                }

                Rectangle { height: 4px; }

                // Appearance
                nav-appearance := Rectangle {
                    height: 42px;
                    border-radius: 8px;
                    x: 8px;
                    width: parent.width - 16px;
                    background: root.current-page == 1 ? #353535 : (ta-appearance.has-hover ? root.hover-bg : transparent);
                    animate background { duration: 120ms; }
                    Rectangle {
                        x: 0px;
                        y: 8px;
                        width: 3px;
                        height: parent.height - 16px;
                        border-radius: 2px;
                        background: root.current-page == 1 ? root.accent : transparent;
                    }
                    HorizontalBox {
                        padding-left: 16px;
                        spacing: 10px;
                        Text {
                            text: "◑";
                            font-size: 15px;
                            color: root.current-page == 1 ? root.text-primary : root.text-muted;
                            vertical-alignment: center;
                            width: 18px;
                        }
                        Text {
                            text: "Appearance";
                            font-size: 14px;
                            font-weight: root.current-page == 1 ? 600 : 400;
                            color: root.current-page == 1 ? root.text-primary : root.text-secondary;
                            vertical-alignment: center;
                        }
                    }
                    ta-appearance := TouchArea { clicked => { root.current-page = 1; } }
                }

                Rectangle { height: 4px; }

                // Hotkeys
                nav-hotkeys := Rectangle {
                    height: 42px;
                    border-radius: 8px;
                    x: 8px;
                    width: parent.width - 16px;
                    background: root.current-page == 2 ? #353535 : (ta-hotkeys.has-hover ? root.hover-bg : transparent);
                    animate background { duration: 120ms; }
                    Rectangle {
                        x: 0px;
                        y: 8px;
                        width: 3px;
                        height: parent.height - 16px;
                        border-radius: 2px;
                        background: root.current-page == 2 ? root.accent : transparent;
                    }
                    HorizontalBox {
                        padding-left: 16px;
                        spacing: 10px;
                        Text {
                            text: "⌨";
                            font-size: 15px;
                            color: root.current-page == 2 ? root.text-primary : root.text-muted;
                            vertical-alignment: center;
                            width: 18px;
                        }
                        Text {
                            text: "Hotkeys";
                            font-size: 14px;
                            font-weight: root.current-page == 2 ? 600 : 400;
                            color: root.current-page == 2 ? root.text-primary : root.text-secondary;
                            vertical-alignment: center;
                        }
                    }
                    ta-hotkeys := TouchArea { clicked => { root.current-page = 2; } }
                }

                Rectangle { height: 4px; }

                // Agent
                nav-agent := Rectangle {
                    height: 42px;
                    border-radius: 8px;
                    x: 8px;
                    width: parent.width - 16px;
                    background: root.current-page == 3 ? #353535 : (ta-agent.has-hover ? root.hover-bg : transparent);
                    animate background { duration: 120ms; }
                    Rectangle {
                        x: 0px;
                        y: 8px;
                        width: 3px;
                        height: parent.height - 16px;
                        border-radius: 2px;
                        background: root.current-page == 3 ? root.accent : transparent;
                    }
                    HorizontalBox {
                        padding-left: 16px;
                        spacing: 10px;
                        Text {
                            text: "🤖";
                            font-size: 15px;
                            color: root.current-page == 3 ? root.text-primary : root.text-muted;
                            vertical-alignment: center;
                            width: 18px;
                        }
                        Text {
                            text: "Agent";
                            font-size: 14px;
                            font-weight: root.current-page == 3 ? 600 : 400;
                            color: root.current-page == 3 ? root.text-primary : root.text-secondary;
                            vertical-alignment: center;
                        }
                    }
                    ta-agent := TouchArea { clicked => { root.current-page = 3; } }
                }

                Rectangle { height: 4px; }

                // Database
                nav-database := Rectangle {
                    height: 42px;
                    border-radius: 8px;
                    x: 8px;
                    width: parent.width - 16px;
                    background: root.current-page == 4 ? #353535 : (ta-database.has-hover ? root.hover-bg : transparent);
                    animate background { duration: 120ms; }
                    Rectangle {
                        x: 0px;
                        y: 8px;
                        width: 3px;
                        height: parent.height - 16px;
                        border-radius: 2px;
                        background: root.current-page == 4 ? root.accent : transparent;
                    }
                    HorizontalBox {
                        padding-left: 16px;
                        spacing: 10px;
                        Text {
                            text: "🗄";
                            font-size: 15px;
                            color: root.current-page == 4 ? root.text-primary : root.text-muted;
                            vertical-alignment: center;
                            width: 18px;
                        }
                        Text {
                            text: "Database";
                            font-size: 14px;
                            font-weight: root.current-page == 4 ? 600 : 400;
                            color: root.current-page == 4 ? root.text-primary : root.text-secondary;
                            vertical-alignment: center;
                        }
                    }
                    ta-database := TouchArea { clicked => { root.current-page = 4; } }
                }

                Rectangle { vertical-stretch: 1; }

                // Thin divider above About
                Rectangle { height: 1px; background: root.border-color; }
                Rectangle { height: 8px; }

                // About
                nav-about := Rectangle {
                    height: 42px;
                    border-radius: 8px;
                    x: 8px;
                    width: parent.width - 16px;
                    background: root.current-page == 5 ? #353535 : (ta-about.has-hover ? root.hover-bg : transparent);
                    animate background { duration: 120ms; }
                    Rectangle {
                        x: 0px;
                        y: 8px;
                        width: 3px;
                        height: parent.height - 16px;
                        border-radius: 2px;
                        background: root.current-page == 5 ? root.accent : transparent;
                    }
                    HorizontalBox {
                        padding-left: 16px;
                        spacing: 10px;
                        Text {
                            text: "ℹ";
                            font-size: 15px;
                            color: root.current-page == 5 ? root.text-primary : root.text-muted;
                            vertical-alignment: center;
                            width: 18px;
                        }
                        Text {
                            text: "About";
                            font-size: 14px;
                            font-weight: root.current-page == 5 ? 600 : 400;
                            color: root.current-page == 5 ? root.text-primary : root.text-secondary;
                            vertical-alignment: center;
                        }
                    }
                    ta-about := TouchArea { clicked => { root.current-page = 5; } }
                }



                Rectangle { height: 16px; }
            }
        }
        
        // Main Content Area
        Rectangle {
            background: root.bg-color;
            
            VerticalBox {
                padding: 0;
                spacing: 0;
                
                ScrollView {
                    VerticalBox {
                        alignment: start;
                        padding: 24px;
                        spacing: 12px;
                    
                    // General Page
                    if root.current-page == 0: VerticalBox {
                        alignment: start;
                        spacing: 20px;

                        // Page header
                        VerticalBox {
                            spacing: 4px;
                            Text {
                                text: "General";
                                font-size: 22px;
                                font-weight: 700;
                                color: root.text-primary;
                            }
                            Text {
                                text: "Launcher behavior and startup preferences";
                                font-size: 13px;
                                color: root.text-muted;
                            }
                        }

                        // Section: Behavior
                        VerticalBox {
                            spacing: 2px;
                            Text {
                                text: "BEHAVIOR";
                                font-size: 11px;
                                font-weight: 600;
                                color: root.text-muted;
                                letter-spacing: 1px;
                            }
                            Rectangle { height: 6px; }

                            // Run on startup row
                            Rectangle {
                                background: root.card-bg;
                                border-radius: 8px;
                                border-color: root.border-color;
                                border-width: 1px;
                                height: 64px;
                                HorizontalBox {
                                    padding-left: 20px;
                                    padding-right: 20px;
                                    spacing: 16px;

                                    VerticalBox {
                                        alignment: center;
                                        spacing: 2px;
                                        Text { text: "Run on startup"; color: root.text-primary; font-size: 14px; font-weight: 600; }
                                        Text { text: "Launch OmniSearch when Windows starts"; color: root.text-muted; font-size: 12px; }
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    VerticalBox {
                                        alignment: center;
                                        ToggleSwitch {
                                            checked <=> root.run-on-startup;
                                            toggled => {
                                                root.save-settings();
                                            }
                                        }
                                    }
                                }
                            }

                            Rectangle { height: 6px; }

                            // Hide on lose focus row
                            Rectangle {
                                background: root.card-bg;
                                border-radius: 8px;
                                border-color: root.border-color;
                                border-width: 1px;
                                height: 64px;
                                HorizontalBox {
                                    padding-left: 20px;
                                    padding-right: 20px;
                                    spacing: 16px;

                                    VerticalBox {
                                        alignment: center;
                                        spacing: 2px;
                                        Text { text: "Hide on lose focus"; color: root.text-primary; font-size: 14px; font-weight: 600; }
                                        Text { text: "Dismiss launcher when it loses keyboard focus"; color: root.text-muted; font-size: 12px; }
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    VerticalBox {
                                        alignment: center;
                                        ToggleSwitch {
                                            checked <=> root.hide-on-lose-focus;
                                            toggled => {
                                                root.save-settings();
                                            }
                                        }
                                    }
                                }
                            }

                            Rectangle { height: 6px; }

                            // Show taskbar when Omnisearch is opened row
                            Rectangle {
                                background: root.card-bg;
                                border-radius: 8px;
                                border-color: root.border-color;
                                border-width: 1px;
                                height: 64px;
                                HorizontalBox {
                                    padding-left: 20px;
                                    padding-right: 20px;
                                    spacing: 16px;

                                    VerticalBox {
                                        alignment: center;
                                        spacing: 2px;
                                        Text { text: "Show taskbar when Omnisearch is opened"; color: root.text-primary; font-size: 14px; font-weight: 600; }
                                        Text { text: "Temporarily show taskbar when omnisearch is opened, useful for auto-hidden taskbars"; color: root.text-muted; font-size: 12px; }
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    VerticalBox {
                                        alignment: center;
                                        ToggleSwitch {
                                            checked <=> root.show-taskbar;
                                            toggled => {
                                                root.save-settings();
                                            }
                                        }
                                    }
                                }
                            }

                            Rectangle { height: 6px; }

                            // Search Window Location row
                            Rectangle {
                                background: root.card-bg;
                                border-radius: 8px;
                                border-color: root.border-color;
                                border-width: 1px;
                                height: 72px;
                                HorizontalBox {
                                    padding-left: 20px;
                                    padding-right: 20px;
                                    spacing: 16px;

                                    VerticalBox {
                                        alignment: center;
                                        spacing: 2px;
                                        Text { text: "Search window location"; color: root.text-primary; font-size: 14px; font-weight: 600; }
                                        Text { text: "Monitor/position where the launcher window appears"; color: root.text-muted; font-size: 12px; }
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    VerticalBox {
                                        alignment: center;
                                        CustomDropdown {
                                            width: 220px;
                                            current-index: root.window-location == "Remember Last Position" ? 0 :
                                                           root.window-location == "Monitor with Mouse Cursor" ? 1 :
                                                           root.window-location == "Monitor with Focused Window" ? 2 :
                                                           root.window-location == "Primary Monitor" ? 3 :
                                                           root.window-location == "Custom Monitor" ? 4 : 1;
                                            model: [
                                                "Remember Last Position",
                                                "Monitor with Mouse Cursor",
                                                "Monitor with Focused Window",
                                                "Primary Monitor",
                                                "Custom Monitor"
                                            ];
                                            selected(val) => {
                                                root.window-location = val;
                                                root.save-settings();
                                            }
                                        }
                                    }
                                }
                            }

                            Rectangle { height: 120px; }
                        }
                    }
                    
                    // Appearance Page
                    if root.current-page == 1: VerticalBox {
                        alignment: start;
                        spacing: 16px;
                        
                        Text { text: "Appearance"; font-size: 26px; font-weight: 600; color: root.text-primary; }
                        
                        // Preview & Edits Container (At the Top!)
                        HorizontalBox {
                            spacing: 16px;
                            
                            // Left Preview Area
                            Rectangle {
                                border-radius: 8px;
                                border-width: 1px;
                                border-color: root.border-color;
                                height: 440px;
                                horizontal-stretch: 1;
                                clip: true;

                                // Background image (User's wallpaper)
                                if root.has-desktop-wallpaper : Image {
                                    source: root.desktop-wallpaper;
                                    image-fit: fill;
                                    width: 100%;
                                    height: 100%;
                                }

                                // Fallback gradient if no wallpaper is loaded
                                if !root.has-desktop-wallpaper : Rectangle {
                                    background: @linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
                                    width: 100%;
                                    height: 100%;
                                }

                                // The Mockup Launcher Popup (exactly matching the user's photos)
                                Rectangle {
                                    width: 440px;
                                    height: 352px;
                                    background: root.theme-mode == "Light" ? #ffffff : (root.theme-mode == "NordDarker" ? #232731 : #1c1c1c);
                                    border-radius: 12px;
                                    border-width: 1px;
                                    border-color: root.theme-mode == "Light" ? #e0e0e0 : (root.theme-mode == "NordDarker" ? #3b4252 : #2d2d2d);
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;

                                    VerticalBox {
                                        padding: 0;
                                        spacing: 0;
                                        
                                        // Mockup Search Input Box
                                        Rectangle {
                                            height: root.search-bar-height * 0.7px;

                                            Rectangle {
                                                y: parent.height - 1px;
                                                height: 1px;
                                                background: root.theme-mode == "Light" ? #f2f2f2 : (root.theme-mode == "NordDarker" ? #3b4252 : #2a2a2a);
                                            }

                                            HorizontalBox {
                                                padding-left: 16px;
                                                padding-right: 16px;
                                                spacing: 12px;
                                                alignment: center;
                                                
                                                // Search Icon
                                                Text {
                                                    text: "⌕";
                                                    font-size: root.query-font-size * 0.75px;
                                                    color: root.theme-mode == "Light" ? #a0a0a0 : (root.theme-mode == "NordDarker" ? #81a1c1 : #888888);
                                                    vertical-alignment: center;
                                                }

                                                // Search Text Placeholder or Caret cursor
                                                if root.show-placeholder : Text {
                                                    text: "Search files, code, PDFs, OCR...";
                                                    font-family: root.query-font-family;
                                                    font-size: root.query-font-size * 0.65px;
                                                    font-weight: root.query-font-weight == "Bold" ? 700 : (root.query-font-weight == "Semi-Bold" ? 600 : 400);
                                                    color: root.theme-mode == "Light" ? #8e8e93 : (root.theme-mode == "NordDarker" ? #4c566a : #6b6b6b);
                                                    vertical-alignment: center;
                                                }

                                                if !root.show-placeholder : Rectangle {
                                                    width: 2px;
                                                    height: root.query-font-size * 0.75px;
                                                    background: root.theme-mode == "Light" ? #000000 : (root.theme-mode == "NordDarker" ? #88c0d0 : #ffffff);
                                                    opacity: 0.95;
                                                }

                                                Rectangle { horizontal-stretch: 1; }
                                                
                                                // Microphone Icon
                                                Text {
                                                    text: "🎙";
                                                    font-size: 14px;
                                                    color: root.theme-mode == "Light" ? #a0a0a0 : (root.theme-mode == "NordDarker" ? #81a1c1 : #888888);
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }

                                        // Mockup Results Area
                                        VerticalBox {
                                            padding-left: 8px;
                                            padding-right: 8px;
                                            padding-top: 6px;
                                            padding-bottom: 6px;
                                            spacing: 4px;

                                            // Mockup Item 1: Browser Bookmarks
                                            Rectangle {
                                                height: 34px;
                                                background: transparent;
                                                border-radius: 4px;
                                                HorizontalBox {
                                                    padding-left: 8px;
                                                    padding-right: 8px;
                                                    spacing: 8px;
                                                    alignment: center;
                                                    Text { text: "⭐"; font-size: 14px; vertical-alignment: center; }
                                                    VerticalBox {
                                                        alignment: center;
                                                        spacing: 0;
                                                        Text { text: "Browser Bookmarks"; font-size: 11px; font-weight: 600; color: root.theme-mode == "Light" ? #222222 : #d8dee9; }
                                                        Text { text: "Browser > Bookmarks"; font-size: 9px; color: root.theme-mode == "Light" ? #888888 : #4c566a; }
                                                    }
                                                    Rectangle { horizontal-stretch: 1; }
                                                    Text { text: "Browser"; font-size: 9px; color: root.theme-mode == "Light" ? #777777 : #4c566a; vertical-alignment: center; }
                                                }
                                            }

                                            // Mockup Item 2: Browser History
                                            Rectangle {
                                                height: 34px;
                                                background: transparent;
                                                border-radius: 4px;
                                                HorizontalBox {
                                                    padding-left: 8px;
                                                    padding-right: 8px;
                                                    spacing: 8px;
                                                    alignment: center;
                                                    Text { text: "🖥️"; font-size: 14px; vertical-alignment: center; }
                                                    VerticalBox {
                                                        alignment: center;
                                                        spacing: 0;
                                                        Text { text: "Browser History"; font-size: 11px; font-weight: 600; color: root.theme-mode == "Light" ? #222222 : #d8dee9; }
                                                        Text { text: "Browser > History"; font-size: 9px; color: root.theme-mode == "Light" ? #888888 : #4c566a; }
                                                    }
                                                    Rectangle { horizontal-stretch: 1; }
                                                    Text { text: "Browser"; font-size: 9px; color: root.theme-mode == "Light" ? #777777 : #4c566a; vertical-alignment: center; }
                                                }
                                            }

                                            // Mockup Item 3: Git Commits (Selected / Active)
                                            Rectangle {
                                                height: 34px;
                                                background: root.theme-mode == "Light" ? #e5e5e5 : (root.theme-mode == "NordDarker" ? #3b4252 : #2f2f2f);
                                                border-radius: 4px;
                                                HorizontalBox {
                                                    padding-left: 8px;
                                                    padding-right: 8px;
                                                    spacing: 8px;
                                                    alignment: center;
                                                    Text { text: "🔍"; font-size: 14px; vertical-alignment: center; }
                                                    VerticalBox {
                                                        alignment: center;
                                                        spacing: 0;
                                                        Text { text: "Git Commits"; font-size: 11px; font-weight: 600; color: root.theme-mode == "Light" ? #111111 : #ffffff; }
                                                        Text { text: "Git > Commits"; font-size: 9px; color: root.theme-mode == "Light" ? #666666 : #bbbbbb; }
                                                    }
                                                    Rectangle { horizontal-stretch: 1; }
                                                    Text { text: "Git"; font-size: 9px; color: root.theme-mode == "Light" ? #555555 : #999999; vertical-alignment: center; }
                                                }
                                            }

                                            // Mockup Item 4: Clipboard History
                                            Rectangle {
                                                height: 34px;
                                                background: transparent;
                                                border-radius: 4px;
                                                HorizontalBox {
                                                    padding-left: 8px;
                                                    padding-right: 8px;
                                                    spacing: 8px;
                                                    alignment: center;
                                                    Text { text: "📋"; font-size: 14px; vertical-alignment: center; }
                                                    VerticalBox {
                                                        alignment: center;
                                                        spacing: 0;
                                                        Text { text: "Clipboard History"; font-size: 11px; font-weight: 600; color: root.theme-mode == "Light" ? #222222 : #d8dee9; }
                                                        Text { text: "Clipboard > History"; font-size: 9px; color: root.theme-mode == "Light" ? #888888 : #4c566a; }
                                                    }
                                                    Rectangle { horizontal-stretch: 1; }
                                                    Text { text: "Clipboard"; font-size: 9px; color: root.theme-mode == "Light" ? #777777 : #4c566a; vertical-alignment: center; }
                                                }
                                            }

                                            // Mockup Item 5: Local Files
                                            Rectangle {
                                                height: 34px;
                                                background: transparent;
                                                border-radius: 4px;
                                                HorizontalBox {
                                                    padding-left: 8px;
                                                    padding-right: 8px;
                                                    spacing: 8px;
                                                    alignment: center;
                                                    Text { text: "📁"; font-size: 14px; vertical-alignment: center; }
                                                    VerticalBox {
                                                        alignment: center;
                                                        spacing: 0;
                                                        Text { text: "Local Files"; font-size: 11px; font-weight: 600; color: root.theme-mode == "Light" ? #222222 : #d8dee9; }
                                                        Text { text: "Local > Files"; font-size: 9px; color: root.theme-mode == "Light" ? #888888 : #4c566a; }
                                                    }
                                                    Rectangle { horizontal-stretch: 1; }
                                                    Text { text: "Local"; font-size: 9px; color: root.theme-mode == "Light" ? #777777 : #4c566a; vertical-alignment: center; }
                                                }
                                            }

                                            // Mockup Item 6: Source Code
                                            Rectangle {
                                                height: 34px;
                                                background: transparent;
                                                border-radius: 4px;
                                                HorizontalBox {
                                                    padding-left: 8px;
                                                    padding-right: 8px;
                                                    spacing: 8px;
                                                    alignment: center;
                                                    Text { text: "📄"; font-size: 14px; vertical-alignment: center; }
                                                    VerticalBox {
                                                        alignment: center;
                                                        spacing: 0;
                                                        Text { text: "Source Code"; font-size: 11px; font-weight: 600; color: root.theme-mode == "Light" ? #222222 : #d8dee9; }
                                                        Text { text: "Local > Source Code"; font-size: 9px; color: root.theme-mode == "Light" ? #888888 : #4c566a; }
                                                    }
                                                    Rectangle { horizontal-stretch: 1; }
                                                    Text { text: "Code"; font-size: 9px; color: root.theme-mode == "Light" ? #777777 : #4c566a; vertical-alignment: center; }
                                                }
                                            }

                                            // Mockup Item 7: Search Screenshots
                                            Rectangle {
                                                height: 34px;
                                                background: transparent;
                                                border-radius: 4px;
                                                HorizontalBox {
                                                    padding-left: 8px;
                                                    padding-right: 8px;
                                                    spacing: 8px;
                                                    alignment: center;
                                                    Text { text: "📄"; font-size: 14px; vertical-alignment: center; }
                                                    VerticalBox {
                                                        alignment: center;
                                                        spacing: 0;
                                                        Text { text: "Search Screenshots"; font-size: 11px; font-weight: 600; color: root.theme-mode == "Light" ? #222222 : #d8dee9; }
                                                        Text { text: "Local > Image Text (OCR)"; font-size: 9px; color: root.theme-mode == "Light" ? #888888 : #4c566a; }
                                                    }
                                                    Rectangle { horizontal-stretch: 1; }
                                                    Text { text: "OCR"; font-size: 9px; color: root.theme-mode == "Light" ? #777777 : #4c566a; vertical-alignment: center; }
                                                }
                                            }

                                            // Mockup Item 8: Agent History
                                            Rectangle {
                                                height: 34px;
                                                background: transparent;
                                                border-radius: 4px;
                                                HorizontalBox {
                                                    padding-left: 8px;
                                                    padding-right: 8px;
                                                    spacing: 8px;
                                                    alignment: center;
                                                    Text { text: "💾"; font-size: 14px; vertical-alignment: center; }
                                                    VerticalBox {
                                                        alignment: center;
                                                        spacing: 0;
                                                        Text { text: "Agent History"; font-size: 11px; font-weight: 600; color: root.theme-mode == "Light" ? #222222 : #d8dee9; }
                                                        Text { text: "AI > Agent runs"; font-size: 9px; color: root.theme-mode == "Light" ? #888888 : #4c566a; }
                                                    }
                                                    Rectangle { horizontal-stretch: 1; }
                                                    Text { text: "AI"; font-size: 9px; color: root.theme-mode == "Light" ? #777777 : #4c566a; vertical-alignment: center; }
                                                }
                                            }
                                        }
                                    }
                                }

                                // Pencil Edit Button top-right
                                Rectangle {
                                    width: 32px;
                                    height: 32px;
                                    background: edit-btn-ta.has-hover ? #ffffff30 : #ffffff1a;
                                    border-radius: 6px;
                                    x: parent.width - self.width - 12px;
                                    y: 12px;
                                    
                                    Text {
                                        text: "✎";
                                        color: #ffffff;
                                        font-size: 14px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                    
                                    edit-btn-ta := TouchArea {
                                        clicked => {
                                            root.edit-panel-expanded = !root.edit-panel-expanded;
                                        }
                                    }
                                }
                            }

                            // Right Edit Panel (Only if expanded)
                            if root.edit-panel-expanded : Rectangle {
                                width: 320px;
                                background: root.card-bg;
                                border-radius: 8px;
                                border-width: 1px;
                                border-color: root.border-color;
                                height: 440px;

                                ScrollView {
                                    VerticalBox {
                                        padding: 16px;
                                        spacing: 12px;
                                        
                                        Text { text: "Edit Layout & Fonts"; font-size: 15px; font-weight: 600; color: root.text-primary; }
                                        
                                        // Search Bar Height Slider
                                        VerticalBox {
                                            spacing: 4px;
                                            HorizontalBox {
                                                padding: 0;
                                                Text { text: "Search Bar Height"; color: root.text-secondary; font-size: 12px; }
                                                Rectangle { horizontal-stretch: 1; }
                                                Text { text: root.search-bar-height + "px"; color: root.accent; font-size: 12px; font-weight: 600; }
                                            }
                                            Slider {
                                                minimum: 40;
                                                maximum: 80;
                                                value: root.search-bar-height;
                                                changed(val) => {
                                                    root.search-bar-height = val;
                                                    root.save-settings();
                                                }
                                            }
                                        }

                                        // Query Box Font Family & Weight & Size
                                        VerticalBox {
                                            spacing: 4px;
                                            Text { text: "Query Font Family"; color: root.text-secondary; font-size: 12px; }
                                            CustomDropdown {
                                                width: 100%;
                                                current-index: root.query-font-family == "Segoe UI Variable" ? 0 :
                                                               root.query-font-family == "Arial" ? 1 :
                                                               root.query-font-family == "Consolas" ? 2 :
                                                               root.query-font-family == "Outfit" ? 3 : 0;
                                                model: ["Segoe UI Variable", "Arial", "Consolas", "Outfit"];
                                                selected(val) => {
                                                    root.query-font-family = val;
                                                    root.save-settings();
                                                }
                                            }
                                            Text { text: "Query Font Weight"; color: root.text-secondary; font-size: 12px; }
                                            CustomDropdown {
                                                width: 100%;
                                                current-index: root.query-font-weight == "Regular" ? 0 :
                                                               root.query-font-weight == "Semi-Bold" ? 1 :
                                                               root.query-font-weight == "Bold" ? 2 : 0;
                                                model: ["Regular", "Semi-Bold", "Bold"];
                                                selected(val) => {
                                                    root.query-font-weight = val;
                                                    root.save-settings();
                                                }
                                            }
                                            HorizontalBox {
                                                padding: 0;
                                                Text { text: "Query Font Size"; color: root.text-secondary; font-size: 12px; }
                                                Rectangle { horizontal-stretch: 1; }
                                                Text { text: root.query-font-size + "px"; color: root.accent; font-size: 12px; font-weight: 600; }
                                            }
                                            Slider {
                                                minimum: 14;
                                                maximum: 32;
                                                value: root.query-font-size;
                                                changed(val) => {
                                                    root.query-font-size = val;
                                                    root.save-settings();
                                                }
                                            }
                                        }

                                        // Item Height Slider
                                        VerticalBox {
                                            spacing: 4px;
                                            HorizontalBox {
                                                padding: 0;
                                                Text { text: "Item Height"; color: root.text-secondary; font-size: 12px; }
                                                Rectangle { horizontal-stretch: 1; }
                                                Text { text: root.item-height + "px"; color: root.accent; font-size: 12px; font-weight: 600; }
                                            }
                                            Slider {
                                                minimum: 40;
                                                maximum: 100;
                                                value: root.item-height;
                                                changed(val) => {
                                                    root.item-height = val;
                                                    root.save-settings();
                                                }
                                            }
                                        }

                                        // Result Title Font Size & Family & Weight
                                        VerticalBox {
                                            spacing: 4px;
                                            Text { text: "Result Title Font Family"; color: root.text-secondary; font-size: 12px; }
                                            CustomDropdown {
                                                width: 100%;
                                                current-index: root.result-title-font-family == "Segoe UI Variable" ? 0 :
                                                               root.result-title-font-family == "Arial" ? 1 :
                                                               root.result-title-font-family == "Consolas" ? 2 :
                                                               root.result-title-font-family == "Outfit" ? 3 : 0;
                                                model: ["Segoe UI Variable", "Arial", "Consolas", "Outfit"];
                                                selected(val) => {
                                                    root.result-title-font-family = val;
                                                    root.save-settings();
                                                }
                                            }
                                            Text { text: "Result Title Font Weight"; color: root.text-secondary; font-size: 12px; }
                                            CustomDropdown {
                                                width: 100%;
                                                current-index: root.result-title-font-weight == "Regular" ? 0 :
                                                               root.result-title-font-weight == "Semi-Bold" ? 1 :
                                                               root.result-title-font-weight == "Bold" ? 2 : 2; // Default to Bold
                                                model: ["Regular", "Semi-Bold", "Bold"];
                                                selected(val) => {
                                                    root.result-title-font-weight = val;
                                                    root.save-settings();
                                                }
                                            }
                                            HorizontalBox {
                                                padding: 0;
                                                Text { text: "Result Title Font Size"; color: root.text-secondary; font-size: 12px; }
                                                Rectangle { horizontal-stretch: 1; }
                                                Text { text: root.result-title-font-size + "px"; color: root.accent; font-size: 12px; font-weight: 600; }
                                            }
                                            Slider {
                                                minimum: 12;
                                                maximum: 24;
                                                value: root.result-title-font-size;
                                                changed(val) => {
                                                    root.result-title-font-size = val;
                                                    root.save-settings();
                                                }
                                            }
                                        }

                                        // Result Subtitle Font Size & Family & Weight
                                        VerticalBox {
                                            spacing: 4px;
                                            Text { text: "Result Subtitle Font Family"; color: root.text-secondary; font-size: 12px; }
                                            CustomDropdown {
                                                width: 100%;
                                                current-index: root.result-subtitle-font-family == "Segoe UI Variable" ? 0 :
                                                               root.result-subtitle-font-family == "Arial" ? 1 :
                                                               root.result-subtitle-font-family == "Consolas" ? 2 :
                                                               root.result-subtitle-font-family == "Outfit" ? 3 : 0;
                                                model: ["Segoe UI Variable", "Arial", "Consolas", "Outfit"];
                                                selected(val) => {
                                                    root.result-subtitle-font-family = val;
                                                    root.save-settings();
                                                }
                                            }
                                            Text { text: "Result Subtitle Font Weight"; color: root.text-secondary; font-size: 12px; }
                                            CustomDropdown {
                                                width: 100%;
                                                current-index: root.result-subtitle-font-weight == "Regular" ? 0 :
                                                               root.result-subtitle-font-weight == "Semi-Bold" ? 1 :
                                                               root.result-subtitle-font-weight == "Bold" ? 2 : 0;
                                                model: ["Regular", "Semi-Bold", "Bold"];
                                                selected(val) => {
                                                    root.result-subtitle-font-weight = val;
                                                    root.save-settings();
                                                }
                                            }
                                            HorizontalBox {
                                                padding: 0;
                                                Text { text: "Result Subtitle Font Size"; color: root.text-secondary; font-size: 12px; }
                                                Rectangle { horizontal-stretch: 1; }
                                                Text { text: root.result-subtitle-font-size + "px"; color: root.accent; font-size: 12px; font-weight: 600; }
                                            }
                                            Slider {
                                                minimum: 10;
                                                maximum: 20;
                                                value: root.result-subtitle-font-size;
                                                changed(val) => {
                                                    root.result-subtitle-font-size = val;
                                                    root.save-settings();
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                        
                        // Launcher theme row
                        Text { text: "Launcher Theme"; font-size: 13px; color: root.text-muted; }
                        Rectangle {
                            background: root.card-bg;
                            border-radius: 8px;
                            border-color: root.border-color;
                            border-width: 1px;
                            padding: 16px;
                            HorizontalBox {
                                spacing: 12px;
                                alignment: start;
                                // Light card
                                Rectangle {
                                    height: 90px;
                                    width: 130px;
                                    border-radius: 8px;
                                    border-width: root.theme-mode == "Light" ? 2px : 1px;
                                    border-color: root.theme-mode == "Light" ? #1d90f3 : root.border-color;
                                    background: #ffffff;
                                    VerticalBox {
                                        padding: 10px;
                                        spacing: 6px;
                                        Text { text: "Light"; color: #111111; font-weight: 600; font-size: 12px; }
                                        Rectangle { height: 16px; border-radius: 4px; background: #f2f2f2; }
                                        Rectangle { height: 16px; border-radius: 4px; background: #e5e5e5; }
                                    }
                                    TouchArea { clicked => { root.theme-mode = "Light"; root.save-settings(); } }
                                }
                                // Dark card
                                Rectangle {
                                    height: 90px;
                                    width: 130px;
                                    border-radius: 8px;
                                    border-width: root.theme-mode == "Dark" ? 2px : 1px;
                                    border-color: root.theme-mode == "Dark" ? #1d90f3 : root.border-color;
                                    background: #1e1e1e;
                                    VerticalBox {
                                        padding: 10px;
                                        spacing: 6px;
                                        Text { text: "Dark"; color: #ffffff; font-weight: 600; font-size: 12px; }
                                        Rectangle { height: 16px; border-radius: 4px; background: #2f2f2f; }
                                        Rectangle { height: 16px; border-radius: 4px; background: #3a3a3a; }
                                    }
                                    TouchArea { clicked => { root.theme-mode = "Dark"; root.save-settings(); } }
                                }
                                // Nord card
                                Rectangle {
                                    height: 90px;
                                    width: 130px;
                                    border-radius: 8px;
                                    border-width: root.theme-mode == "NordDarker" ? 2px : 1px;
                                    border-color: root.theme-mode == "NordDarker" ? #1d90f3 : root.border-color;
                                    background: #2e3440;
                                    VerticalBox {
                                        padding: 10px;
                                        spacing: 6px;
                                        Text { text: "Nord Dark"; color: #e5e9f0; font-weight: 600; font-size: 12px; }
                                        Rectangle { height: 16px; border-radius: 4px; background: #3b4252; }
                                        Rectangle { height: 16px; border-radius: 4px; background: #4c566a; }
                                    }
                                    TouchArea { clicked => { root.theme-mode = "NordDarker"; root.save-settings(); } }
                                }
                            }
                        }

                        // Show placeholder setting
                        Rectangle {
                            background: root.card-bg;
                            border-radius: 8px;
                            border-color: root.border-color;
                            border-width: 1px;
                            height: 64px;
                            HorizontalBox {
                                padding-left: 20px;
                                padding-right: 20px;
                                spacing: 16px;
                                VerticalBox {
                                    alignment: center;
                                    spacing: 2px;
                                    Text { text: "Show placeholder"; color: root.text-primary; font-size: 14px; font-weight: 600; }
                                    Text { text: "Display placeholder when query is empty"; color: root.text-muted; font-size: 12px; }
                                }
                                Rectangle { horizontal-stretch: 1; }
                                VerticalBox {
                                    alignment: center;
                                    ToggleSwitch {
                                        checked <=> root.show-placeholder;
                                        toggled => {
                                            root.save-settings();
                                        }
                                    }
                                }
                            }
                        }

                        // Bottom Spacer
                        Rectangle { height: 60px; }
                    }
                    
                    // Hotkeys Page
                    if root.current-page == 2: VerticalBox {
                        alignment: start;
                        spacing: 14px;
                        Text { text: "Hotkeys"; font-size: 26px; font-weight: 600; color: root.text-primary; }
                        Text { text: "Keyboard shortcuts used by the launcher"; font-size: 13px; color: root.text-muted; }

                        Rectangle {
                            background: root.card-bg;
                            border-radius: 8px;
                            border-color: root.border-color;
                            border-width: 1px;
                            VerticalBox {
                                spacing: 0px;

                                Rectangle {
                                    height: 78px;
                                    background: ta-launcher-row.has-hover ? root.hover-bg : transparent;
                                    animate background { duration: 120ms; }

                                    HorizontalBox {
                                        padding-left: 20px;
                                        padding-right: 20px;
                                        spacing: 14px;

                                        Rectangle {
                                            width: 34px;
                                            height: 34px;
                                            border-radius: 7px;
                                            background: #1f6feb;
                                            Text {
                                                text: "K";
                                                color: #ffffff;
                                                font-size: 16px;
                                                font-weight: 700;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }

                                        VerticalBox {
                                            alignment: center;
                                            spacing: 2px;
                                            Text { text: "Open launcher"; color: root.text-primary; font-size: 15px; font-weight: 600; }
                                            Text { text: "Toggles the search window"; color: root.text-muted; font-size: 12px; }
                                        }

                                        Rectangle { horizontal-stretch: 1; }

                                        Rectangle {
                                            width: 186px;
                                            height: 36px;
                                            border-radius: 6px;
                                            border-width: root.recording-hotkey ? 2px : 1px;
                                            border-color: root.recording-hotkey ? #3b82f6 : root.border-color;
                                            background: root.recording-hotkey ? #13243d : root.bg-color;
                                            Text {
                                                text: root.recording-hotkey ? "Press shortcut..." : root.global-hotkey;
                                                color: root.recording-hotkey ? #93c5fd : root.text-primary;
                                                font-size: 13px;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    ta-launcher-row := TouchArea {
                                        clicked => {
                                            root.hotkey-error = "";
                                            root.previous-hotkey = root.global-hotkey;
                                            root.recording-hotkey = true;
                                            root.set-hotkey-recording(true);
                                            hotkey-capture.focus();
                                        }
                                    }
                                }

                                Rectangle { height: 1px; background: root.border-color; }

                                Rectangle {
                                    height: 72px;
                                    HorizontalBox {
                                        padding-left: 20px;
                                        padding-right: 20px;
                                        spacing: 14px;

                                        Rectangle {
                                            width: 34px;
                                            height: 34px;
                                            border-radius: 7px;
                                            background: #303030;
                                            Text {
                                                text: "M";
                                                color: root.text-secondary;
                                                font-size: 16px;
                                                font-weight: 700;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }

                                        VerticalBox {
                                            alignment: center;
                                            spacing: 2px;
                                            Text { text: "Voice dictation"; color: root.text-primary; font-size: 15px; font-weight: 600; }
                                            Text { text: "Reserved by the launcher backend"; color: root.text-muted; font-size: 12px; }
                                        }

                                        Rectangle { horizontal-stretch: 1; }

                                        Rectangle {
                                            width: 186px;
                                            height: 34px;
                                            border-radius: 6px;
                                            border-width: 1px;
                                            border-color: root.border-color;
                                            background: root.bg-color;
                                            Text {
                                                text: root.voice-hotkey;
                                                color: root.text-muted;
                                                font-size: 13px;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        if root.hotkey-error != "": Rectangle {
                            height: 42px;
                            border-radius: 8px;
                            background: #3a1d1d;
                            border-color: #7f1d1d;
                            border-width: 1px;
                            HorizontalBox {
                                padding-left: 14px;
                                padding-right: 14px;
                                Text {
                                    text: root.hotkey-error;
                                    color: #fecaca;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        Rectangle {
                            background: root.card-bg;
                            border-radius: 8px;
                            border-color: root.border-color;
                            border-width: 1px;
                            height: 66px;
                            HorizontalBox {
                                padding-left: 20px;
                                padding-right: 20px;
                                Text { text: "Invalid shortcuts are rejected before saving."; vertical-alignment: center; color: root.text-muted; font-size: 13px; }
                                Rectangle { horizontal-stretch: 1; }
                                HorizontalBox {
                                    spacing: 8px;
                                    Text { text: "Editable"; color: root.text-muted; font-size: 12px; vertical-alignment: center; }
                                    Rectangle { width: 8px; height: 8px; border-radius: 4px; background: #22c55e; }
                                }
                            }
                        }
                    }
                    
                    // Agent Page
                    if root.current-page == 3: VerticalBox {
                        alignment: start;
                        spacing: 20px;

                        // Page header
                        VerticalBox {
                            spacing: 4px;
                            Text {
                                text: "Agent Settings";
                                font-size: 22px;
                                font-weight: 700;
                                color: root.text-primary;
                            }
                            Text {
                                text: "Configure settings for autonomous agent and AI helper features";
                                font-size: 13px;
                                color: root.text-muted;
                            }
                        }

                        // Section: API Settings
                        VerticalBox {
                            spacing: 12px;
                            Text {
                                text: "AI & ENDPOINT CONFIGURATION";
                                font-size: 11px;
                                font-weight: 600;
                                color: root.text-muted;
                                letter-spacing: 1px;
                            }
                            
                            Rectangle {
                                background: root.card-bg;
                                border-radius: 8px;
                                border-color: root.border-color;
                                border-width: 1px;
                                padding: 20px;
                                
                                VerticalBox {
                                    spacing: 16px;
                                    
                                    // API Key Row
                                    VerticalBox {
                                        spacing: 6px;
                                        Text { text: "API Key"; color: root.text-primary; font-size: 14px; font-weight: 600; }
                                        Text { text: "OpenCode Zen or DeepSeek API Key"; color: root.text-muted; font-size: 12px; }
                                        HorizontalBox {
                                            padding: 0;
                                            spacing: 8px;
                                            LineEdit {
                                                text: root.agent-api-key;
                                                placeholder-text: "sk-...";
                                                input-type: root.show-api-key ? InputType.text : InputType.password;
                                                edited(t) => {
                                                    root.agent-api-key = t;
                                                    root.save-settings();
                                                }
                                            }
                                            Button {
                                                text: root.show-api-key ? "Hide" : "Show";
                                                width: 60px;
                                                clicked => { root.show-api-key = !root.show-api-key; }
                                            }
                                        }
                                    }
                                    
                                    // Endpoint Row
                                    VerticalBox {
                                        spacing: 6px;
                                        Text { text: "API Endpoint"; color: root.text-primary; font-size: 14px; font-weight: 600; }
                                        Text { text: "Target endpoint URL for OpenAI-compatible chat completions"; color: root.text-muted; font-size: 12px; }
                                        LineEdit {
                                            text: root.agent-endpoint;
                                            placeholder-text: "https://api.deepseek.com/chat/completions";
                                            edited(t) => {
                                                root.agent-endpoint = t;
                                                root.save-settings();
                                            }
                                        }
                                    }
                                    
                                    // Model Row
                                    VerticalBox {
                                        spacing: 6px;
                                        Text { text: "Model Name"; color: root.text-primary; font-size: 14px; font-weight: 600; }
                                        Text { text: "The name of the model to request"; color: root.text-muted; font-size: 12px; }
                                        LineEdit {
                                            text: root.agent-model;
                                            placeholder-text: "deepseek-chat";
                                            edited(t) => {
                                                root.agent-model = t;
                                                root.save-settings();
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // Section: Safety
                        VerticalBox {
                            spacing: 12px;
                            Text {
                                text: "SAFETY & CONFIRMATIONS";
                                font-size: 11px;
                                font-weight: 600;
                                color: root.text-muted;
                                letter-spacing: 1px;
                            }
                            
                            Rectangle {
                                background: root.card-bg;
                                border-radius: 8px;
                                border-color: root.border-color;
                                border-width: 1px;
                                height: 64px;
                                HorizontalBox {
                                    padding-left: 20px;
                                    padding-right: 20px;
                                    spacing: 16px;
                                    Rectangle {
                                        width: 36px;
                                        height: 36px;
                                        border-radius: 9px;
                                        background: #3b2a22;
                                        Text {
                                            text: "⚠";
                                            color: #f97316;
                                            font-size: 16px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                    VerticalBox {
                                        alignment: center;
                                        spacing: 2px;
                                        Text { text: "Always approve agent actions"; color: root.text-primary; font-size: 14px; font-weight: 600; }
                                        Text { text: "Execute command line actions automatically without confirmation prompts"; color: root.text-muted; font-size: 12px; }
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    VerticalBox {
                                        alignment: center;
                                        ToggleSwitch {
                                            checked <=> root.agent-always-approve;
                                            toggled => {
                                                root.save-settings();
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                    
                    // Database Page
                    if root.current-page == 4: VerticalBox {
                        alignment: start;
                        spacing: 20px;

                        // Page header
                        VerticalBox {
                            spacing: 4px;
                            Text {
                                text: "Database Settings";
                                font-size: 22px;
                                font-weight: 700;
                                color: root.text-primary;
                            }
                            Text {
                                text: "Manage local search index database and folders to scan";
                                font-size: 13px;
                                color: root.text-muted;
                            }
                        }

                        // Section: Status
                        VerticalBox {
                            spacing: 12px;
                            Text {
                                text: "INDEX STATUS";
                                font-size: 11px;
                                font-weight: 600;
                                color: root.text-muted;
                                letter-spacing: 1px;
                            }
                            
                            Rectangle {
                                background: root.card-bg;
                                border-radius: 8px;
                                border-color: root.border-color;
                                border-width: 1px;
                                padding: 20px;
                                
                                VerticalBox {
                                    spacing: 12px;
                                    
                                    HorizontalBox {
                                        padding: 0;
                                        Text { text: "Total Files Indexed"; color: root.text-secondary; font-size: 13px; }
                                        Rectangle { horizontal-stretch: 1; }
                                        Text { text: root.db-file-count; color: root.text-primary; font-weight: 600; font-size: 13px; }
                                    }
                                    
                                    Rectangle { height: 1px; background: root.border-color; }
                                    
                                    HorizontalBox {
                                        padding: 0;
                                        Text { text: "Last Crawled Time"; color: root.text-secondary; font-size: 13px; }
                                        Rectangle { horizontal-stretch: 1; }
                                        Text { text: root.db-last-indexed; color: root.text-primary; font-weight: 600; font-size: 13px; }
                                    }
                                    
                                    Rectangle { height: 1px; background: root.border-color; }
                                    
                                    HorizontalBox {
                                        padding: 0;
                                        Text { text: "Indexer State"; color: root.text-secondary; font-size: 13px; }
                                        Rectangle { horizontal-stretch: 1; }
                                        HorizontalBox {
                                            spacing: 6px;
                                            if root.db-is-indexing: Rectangle {
                                                width: 8px;
                                                height: 8px;
                                                border-radius: 4px;
                                                background: #f59e0b; // Orange scanning indicator
                                            }
                                            Text {
                                                text: root.db-status;
                                                color: root.db-is-indexing ? #f59e0b : root.text-primary;
                                                font-weight: 600;
                                                font-size: 13px;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // Section: Folders
                        VerticalBox {
                            spacing: 12px;
                            Text {
                                text: "INDEXED DIRECTORIES";
                                font-size: 11px;
                                font-weight: 600;
                                color: root.text-muted;
                                letter-spacing: 1px;
                            }
                            
                            // Add/Rebuild Actions
                            HorizontalBox {
                                padding: 0;
                                spacing: 10px;
                                Button {
                                    text: "Add Directory...";
                                    clicked => { root.add-folder(); }
                                }
                                Button {
                                    text: "Rebuild Index Now";
                                    enabled: !root.db-is-indexing;
                                    clicked => { root.rebuild-index(); }
                                }
                            }
                            
                            // List of directories
                            Rectangle {
                                background: root.card-bg;
                                border-radius: 8px;
                                border-color: root.border-color;
                                border-width: 1px;
                                padding: 12px;
                                
                                VerticalBox {
                                    spacing: 8px;
                                    if root.db-folders.length == 0: Text {
                                        text: "Default Directories (User Profile & Fixed Slices)";
                                        color: root.text-muted;
                                        font-size: 13px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        height: 40px;
                                    }
                                    for folder[idx] in root.db-folders: Rectangle {
                                        background: root.hover-bg;
                                        border-radius: 6px;
                                        height: 38px;
                                        HorizontalBox {
                                            padding-left: 12px;
                                            padding-right: 12px;
                                            Text {
                                                text: folder;
                                                color: root.text-primary;
                                                font-size: 13px;
                                                vertical-alignment: center;
                                            }
                                            Rectangle { horizontal-stretch: 1; }
                                            Button {
                                                text: "Remove";
                                                width: 70px;
                                                clicked => {
                                                    root.remove-folder(idx);
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                    
                    // About Page
                    if root.current-page == 5: VerticalBox {
                        alignment: start;
                        spacing: 24px;
                        Text { text: "About"; font-size: 26px; font-weight: 600; color: root.text-primary; }
                        Rectangle {
                            background: root.card-bg;
                            border-radius: 8px;
                            border-color: root.border-color;
                            border-width: 1px;
                            padding: 32px;
                            VerticalBox {
                                spacing: 12px;
                                Text { text: "opensearch-os"; font-size: 22px; font-weight: 700; color: root.text-primary; }
                                Text { text: "Version 0.1.0"; font-size: 14px; color: root.text-muted; }
                                Text { text: "A blazing fast Win32 search launcher in Rust."; color: root.text-secondary; font-size: 14px; }
                            }
                        }
                    }


                }
            }
        }
    }
}

    hotkey-capture := FocusScope {
        x: -1px;
        y: -1px;
        width: 1px;
        height: 1px;

        key-pressed(event) => {
            if (!root.recording-hotkey) {
                return reject;
            }
            if (event.text == "\u{1b}" || event.text == "Escape" || event.text == "Esc") {
                root.recording-hotkey = false;
                root.global-hotkey = root.previous-hotkey;
                root.set-hotkey-recording(false);
                return accept;
            }
            let hotkey = root.format-hotkey(event.text, event.modifiers.control, event.modifiers.alt, event.modifiers.shift, event.modifiers.meta);
            if (hotkey != "") {
                let status = root.validate-hotkey(hotkey);
                if (status == "OK") {
                    root.hotkey-error = "";
                    root.global-hotkey = hotkey;
                    root.recording-hotkey = false;
                    root.set-hotkey-recording(false);
                    root.save-settings();
                } else {
                    root.hotkey-error = status;
                }
                return accept;
            }
            root.hotkey-error = "Press a supported key with Ctrl, Alt, Shift, or Win.";
            return accept;
        }
    }
}
