                                Rectangle { height: 1px; background: root.border-color; }

                                Rectangle {
                                    height: 72px;
                                    HorizontalBox {
                                        padding-left: 20px;
                                        padding-right: 20px;
                                        spacing: 14px;

                                        Rectangle {
                                            width: 34px;
                                            height: 34px;
                                            border-radius: 7px;
                                            background: #303030;
                                            Text {
                                                text: "M";
                                                color: root.text-secondary;
                                                font-size: 16px;
