                        y: 8px;
                        width: root.current-page == 2 ? 3px : 0px;
                        height: parent.height - 16px;
                        border-radius: 2px;
                        background: root.accent;
                        animate width { duration: 160ms; easing: ease-in-out; }
                    }
                    HorizontalBox {
                        padding-left: 16px;
                        spacing: 10px;
                        Text {
                            text: "\u{e765}";
                            font-family: "Segoe MDL2 Assets";
                            font-size: 16px;
                            color: root.current-page == 2 ? root.text-primary : root.text-muted;
                            vertical-alignment: center;
                            width: 18px;
                        }
                        Text {
                            text: "Hotkeys";
                            font-size: 14px;
                            font-weight: root.current-page == 2 ? 600 : 400;
                            color: root.current-page == 2 ? root.text-primary : root.text-secondary;
                            vertical-alignment: center;
                        }
                    }
                    ta-hotkeys := TouchArea { clicked => { root.current-page = 2; } }
                }

                Rectangle { height: 4px; }

                // Agent
                nav-agent := Rectangle {
                    height: 42px;
                    border-radius: 8px;
                    x: 8px;
                    width: parent.width - 16px;
                    background: root.current-page == 3 ? #353535 : (ta-agent.has-hover ? root.hover-bg : transparent);
                    animate background { duration: 120ms; }
                    Rectangle {
                        x: 0px;
                        y: 8px;
                        width: root.current-page == 3 ? 3px : 0px;
                        height: parent.height - 16px;
                        border-radius: 2px;
                        background: root.accent;
                        animate width { duration: 160ms; easing: ease-in-out; }
                    }
                    HorizontalBox {
                        padding-left: 16px;
                        spacing: 10px;
                        Text {
                            text: "\u{e950}";
                            font-family: "Segoe MDL2 Assets";
                            font-size: 16px;
