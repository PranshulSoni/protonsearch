                // About
                nav-about := Rectangle {
                    height: 42px;
                    border-radius: 8px;
                    x: 8px;
                    width: parent.width - 16px;
                    background: root.current-page == 5 ? #3a3a4a : (ta-about.has-hover ? root.hover-bg : transparent);
                    animate background { duration: 120ms; }
                    Rectangle {
