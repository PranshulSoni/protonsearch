                                spacing: 12px;
                                Rectangle {
                                    height: 106px;
                                    width: 150px;
                                    border-radius: 8px;
                                    border-width: root.theme-mode == "Light" ? 2px : 1px;
                                    border-color: root.theme-mode == "Light" ? #3b82f6 : root.border-color;
