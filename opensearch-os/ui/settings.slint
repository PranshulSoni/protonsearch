                                        spacing: 8px;
                                        Text { text: "Light"; color: #111111; font-weight: 600; }
                                        Rectangle { height: 24px; border-radius: 5px; background: #f2f2f2; }
                                        Rectangle { height: 24px; border-radius: 5px; background: #e5e5e5; }
                                    }
                                    TouchArea {
