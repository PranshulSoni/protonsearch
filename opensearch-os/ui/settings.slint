import { Button, VerticalBox, HorizontalBox, CheckBox, ComboBox, LineEdit, StandardListView, TabWidget, Slider, ScrollView, Palette } from "std-widgets.slint";

export component SettingsWindow inherits Window {
    title: "Settings";
    width: 800px;
    height: 600px;
    
    // Properties to bind to Rust
    in-out property <bool> run-on-startup;
    in-out property <bool> hide-on-lose-focus;
    in-out property <string> theme-mode;
    in-out property <string> global-hotkey;
    
    in-out property <int> window-width;
    in-out property <int> item-height;
    
    // Callbacks to Rust
    callback save-settings();
    callback record-hotkey();
    
    property <int> current-page: 0;
    
    // Theme Tokens
    property <bool> is-light: false; // Locked to dark mode for settings app
    property <color> bg-color: is-light ? #FAFAFA : #1e1e1e;
    property <color> sidebar-bg: is-light ? #F0F0F0 : #252525;
    property <color> card-bg: is-light ? #FFFFFF : #2b2b2b;
    
    property <color> text-primary: is-light ? #111111 : #ffffff;
    property <color> text-secondary: is-light ? #555555 : #cccccc;
    property <color> text-muted: is-light ? #777777 : #aaaaaa;
    
    property <color> hover-bg: is-light ? #E5E5E5 : #2f2f2f;
    property <color> active-bg: is-light ? #D5D5D5 : #3a3a3a;
    property <color> border-color: is-light ? #EAEAEA : #333333;

    background: root.bg-color;

    HorizontalBox {
        padding: 0;
        spacing: 0;
        
        // Sidebar Navigation
        Rectangle {
            width: 220px;
            background: root.sidebar-bg;
            
            VerticalBox {
                padding-top: 32px;
                padding-left: 12px;
                padding-right: 12px;
                spacing: 8px;
                
                Text {
                    text: "opensearch-os";
                    font-size: 18px;
                    font-weight: 700;
                    color: root.text-primary;
                    horizontal-alignment: center;
                }
                
                Rectangle { height: 24px; } // Spacer
                
                // Sidebar Item: General
                Rectangle {
                    height: 36px;
                    border-radius: 6px;
                    background: root.current-page == 0 ? root.active-bg : ta-general.has-hover ? root.hover-bg : transparent;
                    animate background { duration: 150ms; }
                    
                    HorizontalBox {
                        padding-left: 12px;
                        Text { text: "General"; vertical-alignment: center; color: root.current-page == 0 ? root.text-primary : root.text-secondary; font-weight: root.current-page == 0 ? 600 : 400; }
                    }
                    ta-general := TouchArea {
                        clicked => { root.current-page = 0; }
                    }
                }
                
                // Sidebar Item: Appearance
                Rectangle {
                    height: 36px;
                    border-radius: 6px;
                    background: root.current-page == 1 ? root.active-bg : ta-appearance.has-hover ? root.hover-bg : transparent;
                    animate background { duration: 150ms; }
                    
                    HorizontalBox {
                        padding-left: 12px;
                        Text { text: "Appearance"; vertical-alignment: center; color: root.current-page == 1 ? root.text-primary : root.text-secondary; font-weight: root.current-page == 1 ? 600 : 400; }
                    }
                    ta-appearance := TouchArea {
                        clicked => { root.current-page = 1; }
                    }
                }
                
                // Sidebar Item: Hotkeys
                Rectangle {
                    height: 36px;
                    border-radius: 6px;
                    background: root.current-page == 2 ? root.active-bg : ta-hotkeys.has-hover ? root.hover-bg : transparent;
                    animate background { duration: 150ms; }
                    
                    HorizontalBox {
                        padding-left: 12px;
                        Text { text: "Hotkeys"; vertical-alignment: center; color: root.current-page == 2 ? root.text-primary : root.text-secondary; font-weight: root.current-page == 2 ? 600 : 400; }
                    }
                    ta-hotkeys := TouchArea {
                        clicked => { root.current-page = 2; }
                    }
                }
                
                Rectangle { vertical-stretch: 1; } // Spacer pushing About to bottom
                
                // Sidebar Item: About
                Rectangle {
                    height: 36px;
                    border-radius: 6px;
                    background: root.current-page == 3 ? root.active-bg : ta-about.has-hover ? root.hover-bg : transparent;
                    animate background { duration: 150ms; }
                    
                    HorizontalBox {
                        padding-left: 12px;
                        Text { text: "About"; vertical-alignment: center; color: root.current-page == 3 ? root.text-primary : root.text-secondary; font-weight: root.current-page == 3 ? 600 : 400; }
                    }
                    ta-about := TouchArea {
                        clicked => { root.current-page = 3; }
                    }
                }
            }
        }
        
        // Main Content Area
        Rectangle {
            background: root.bg-color;
            
            ScrollView {
                width: 100%;
                height: 100%;
                
                VerticalBox {
                    padding: 24px;
                    spacing: 12px;
                    
                    // General Page
                    if root.current-page == 0: VerticalBox {
                        spacing: 12px;
                        Text { text: "General Settings"; font-size: 26px; font-weight: 600; color: root.text-primary; }
                        
                        Rectangle {
                            background: root.card-bg;
                            border-radius: 8px;
                            border-color: root.border-color;
                            border-width: 1px;
                            padding: 20px;
                            HorizontalBox {
                                Text { text: "Run on startup"; vertical-alignment: center; color: root.text-primary; font-size: 14px; }
                                Rectangle { horizontal-stretch: 1; }
                                CheckBox {
                                    checked: root.run-on-startup;
                                    toggled => {
                                        root.run-on-startup = self.checked;
                                        root.save-settings();
                                    }
                                }
                            }
                        }
                        
                        Rectangle {
                            background: root.card-bg;
                            border-radius: 8px;
                            border-color: root.border-color;
                            border-width: 1px;
                            padding: 20px;
                            HorizontalBox {
                                Text { text: "Hide on lose focus"; vertical-alignment: center; color: root.text-primary; font-size: 14px; }
                                Rectangle { horizontal-stretch: 1; }
                                CheckBox {
                                    checked: root.hide-on-lose-focus;
                                    toggled => {
                                        root.hide-on-lose-focus = self.checked;
                                        root.save-settings();
                                    }
                                }
                            }
                        }
                    }
                    
                    // Appearance Page
                    if root.current-page == 1: VerticalBox {
                        spacing: 12px;
                        Text { text: "Appearance"; font-size: 26px; font-weight: 600; color: root.text-primary; }
                        
                        Rectangle {
                            background: root.card-bg;
                            border-radius: 8px;
                            border-color: root.border-color;
                            border-width: 1px;
                            padding: 20px;
                            HorizontalBox {
                                Text { text: "Theme"; vertical-alignment: center; color: root.text-primary; font-size: 14px; }
                                Rectangle { horizontal-stretch: 1; }
                                HorizontalBox {
                                    width: 160px;
                                    ComboBox {
                                        model: ["Light", "Dark"];
                                        current-value: root.theme-mode;
                                        selected(val) => {
                                            root.theme-mode = val;
                                            root.save-settings();
                                        }
                                    }
                                }
                            }
                        }
                        

                    }
                    
                    // Hotkeys Page
                    if root.current-page == 2: VerticalBox {
                        spacing: 12px;
                        Text { text: "Hotkeys"; font-size: 26px; font-weight: 600; color: root.text-primary; }
                        
                        Rectangle {
                            background: root.card-bg;
                            border-radius: 8px;
                            border-color: root.border-color;
                            border-width: 1px;
                            padding: 20px;
                            HorizontalBox {
                                Text { text: "Global Hotkey"; vertical-alignment: center; color: root.text-primary; font-size: 14px; }
                                Rectangle { horizontal-stretch: 1; }
                                HorizontalBox {
                                    width: 200px;
                                    Button {
                                        text: root.global-hotkey;
                                        clicked => {
                                            root.global-hotkey = "Listening...";
                                            root.record-hotkey();
                                        }
                                    }
                                }
                            }
                        }
                    }
                    
                    // About Page
                    if root.current-page == 3: VerticalBox {
                        spacing: 24px;
                        Text { text: "About"; font-size: 26px; font-weight: 600; color: root.text-primary; }
                        Rectangle {
                            background: root.card-bg;
                            border-radius: 8px;
                            border-color: root.border-color;
                            border-width: 1px;
                            padding: 32px;
                            VerticalBox {
                                spacing: 12px;
                                Text { text: "opensearch-os"; font-size: 22px; font-weight: 700; color: root.text-primary; }
                                Text { text: "Version 0.1.0"; font-size: 14px; color: root.text-muted; }
                                Text { text: "A blazing fast Win32 search launcher in Rust."; color: root.text-secondary; font-size: 14px; }
                            }
                        }
                    }
                }
            }
        }
    }
}
